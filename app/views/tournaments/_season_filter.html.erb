<nav class="flex flex-wrap gap-2">
  <%= link_to "All", tournaments_path,
              class: "px-3 py-2 rounded-lg #{current.blank? ? 'bg-blue-600 text-white' : 'bg-slate-700 text-slate-200'}" %>
  <% tags.each do |tag| %>
    <%= link_to tag, tournaments_path(season: tag),
                class: "px-3 py-2 rounded-lg #{tag == current ? 'bg-blue-600 text-white' : 'bg-slate-700 text-slate-200'}" %>
  <% end %>
</nav>
