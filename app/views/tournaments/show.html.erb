<h1 class="text-2xl font-semibold mt-4 mb-4">
  <%= @tournament.name %>
  <% if @tournament.ended? %>
    <span class="text-xs uppercase tracking-wide text-slate-300 bg-slate-700 rounded px-2 py-1 align-middle ml-2">Completed</span>
  <% end %>
</h1>

<% is_judge   = TournamentJudge.exists?(tournament_id: @tournament.id, user_id: current_user.id) %>
<% is_entered = TournamentEntryMember.joins(:tournament_entry)
                  .exists?(tournament_entries: { tournament_id: @tournament.id }, user_id: current_user.id) %>

<% if @tournament.ended? %>
  <p class="text-slate-400 mb-4">This tournament has ended.</p>
<% elsif is_judge %>
  <p class="text-slate-400 mb-4">You're judging this tournament.</p>
<% elsif is_entered %>
  <%= link_to "Log Catch", new_catch_path, class: "block w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white text-center leading-[3.5rem] #{@tournament.mode_team? ? "mb-2" : "mb-4"}" %>
  <% if @tournament.mode_team? %>
    <%= link_to "Log for teammate", select_teammate_catches_path(tournament_id: @tournament.id), class: "block w-full h-12 px-6 text-base font-medium rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem] mb-4" %>
  <% end %>
<% else %>
  <p class="text-slate-400 italic">You're not entered. Ask an organizer to add you.</p>
<% end %>

<% if @tournament.ends_at.present? %>
  <section class="bg-slate-800 rounded-xl p-4 mb-4">
    <div class="flex items-baseline justify-between">
      <span class="text-sm uppercase tracking-wide text-slate-400"><%= @tournament.ended? ? "Ended" : "Ends" %></span>
      <span class="text-slate-100"><%= @tournament.ends_at.strftime("%b %d, %Y · %l:%M %p") %></span>
    </div>
  </section>
<% end %>

<% slots = @tournament.scoring_slots.includes(:species).order(:id) %>
<% if slots.any? %>
  <section class="bg-slate-800 rounded-xl p-4 mb-4">
    <h2 class="text-sm uppercase tracking-wide text-slate-400 mb-2">Scoring</h2>
    <ul class="text-slate-100 space-y-1">
      <% slots.each do |slot| %>
        <li>
          <% if @tournament.format_biggest_vs_smallest? %>
            Biggest minus smallest <%= slot.species.name.downcase %>
          <% elsif @tournament.format_hidden_length? %>
            Hidden length 12"-22" <%= slot.species.name.downcase %>
          <% elsif slot.slot_count == 1 %>
            Largest <%= slot.species.name.downcase %>
          <% else %>
            Top <%= slot.slot_count %> <%= slot.species.name.downcase.pluralize %>
          <% end %>
        </li>
      <% end %>
    </ul>
    <% if @entry_count.to_i.positive? %>
      <div class="text-sm text-slate-400 border-t border-slate-700 mt-2 pt-2">
        <% if @tournament.mode_team? %>
          <%= pluralize(@angler_count, "angler") %> across <%= pluralize(@entry_count, "team") %>
        <% else %>
          <%= pluralize(@angler_count, "angler") %>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>

<% case @viewer_scope.visibility
   when :full %>
  <%= turbo_stream_from "tournament:#{@tournament.id}:leaderboard:full" %>
<% when :own_entry_only %>
  <%= turbo_stream_from "tournament:#{@tournament.id}:leaderboard:entry:#{@viewer_scope.entry_id}" %>
  <%= turbo_stream_from "tournament:#{@tournament.id}:leaderboard:reveal" %>
<% when :entries_only %>
  <%= turbo_stream_from "tournament:#{@tournament.id}:leaderboard:reveal" %>
<% end %>
<%= render "leaderboard", leaderboard: @leaderboard, tournament: @tournament, viewer_scope: @viewer_scope %>
<%= turbo_frame_tag "catch_photo_modal" %>
