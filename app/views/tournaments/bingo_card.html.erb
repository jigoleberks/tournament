<%# app/views/tournaments/bingo_card.html.erb — @tournament, @entry, @result %>
<h1 class="text-2xl font-semibold mt-4 mb-1"><%= @tournament.name %></h1>
<p class="text-slate-400 mb-4"><%= @entry.display_name %>'s card</p>

<%= turbo_stream_from "bingo_card:#{@tournament.id}:#{@entry.id}" %>
<%# Same suspend-recovery as the leaderboard: iOS kills the Cable socket while
    the PWA is backgrounded and missed square-broadcasts are never replayed. %>
<div data-controller="stream-refresh" hidden></div>
<%= render "tournaments/bingo_card", tournament: @tournament, result: @result %>

<% has_teammates = @tournament.mode_team? && Tournaments::TeammatesFor.call(user: current_user, tournament: @tournament).exists? %>
<%= link_to "Log Catch", (has_teammates ? select_teammate_catches_path : select_species_catches_path),
    class: "block w-full h-14 mt-4 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white text-center leading-[3.5rem]" %>
