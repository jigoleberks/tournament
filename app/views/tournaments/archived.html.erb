<h1 class="text-2xl font-semibold mt-4 mb-4">Completed tournaments</h1>

<% if @tournaments.any? %>
  <ul class="space-y-2">
    <% @tournaments.each do |t| %>
      <% row_classes = "flex flex-wrap items-baseline gap-x-2 px-4 py-3" %>
      <% visible = tournament_leaderboard_visible?(t) %>
      <% name_classes = visible ? "text-lg font-medium text-blue-300" : "text-lg font-medium text-slate-200" %>
      <% row = capture do %>
        <span class="<%= name_classes %>"><%= t.name %></span>
        <span class="text-sm text-slate-400">— ended <%= t.ends_at.strftime("%b %d, %Y") %></span>
        <% if (winner = @winners[t.id]) %>
          <span class="text-sm text-slate-400">— winner — <%= winner.display_name %></span>
        <% end %>
        <% unless visible %>
          <span class="w-full text-xs text-slate-400">Ask an organizer to add you to see the leaderboard.</span>
        <% end %>
      <% end %>
      <li class="bg-slate-800 rounded-lg opacity-75 <%= "active:bg-slate-700" if visible %>">
        <% if visible %>
          <%= link_to t, class: row_classes do %><%= row %><% end %>
        <% else %>
          <div class="<%= row_classes %>"><%= row %></div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic">No archived tournaments yet.</p>
<% end %>

<div class="mt-6">
  <%= link_to "Back", root_path,
              class: "block w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
</div>
