<h1 class="text-2xl font-semibold mt-4 mb-4">Tournaments</h1>
<%= render "season_filter", tags: @season_tags, current: params[:season] %>

<h2 class="text-lg font-semibold mt-6 mb-2">Active</h2>
<% if @active_tournaments.any? %>
  <ul class="space-y-2">
    <% @active_tournaments.each do |t| %>
      <% visible = tournament_leaderboard_visible?(t) %>
      <li class="bg-slate-800 rounded-lg px-4 py-3">
        <% if visible %>
          <%= link_to t.name, t, class: "text-lg font-medium text-blue-300" %>
        <% else %>
          <span class="text-lg font-medium text-slate-200"><%= t.name %></span>
        <% end %>
        <% if t.season_tag.present? %>
          <span class="text-sm text-slate-400">— <%= t.season_tag %></span>
        <% end %>
        <% unless visible %>
          <span class="block text-xs text-slate-400 mt-0.5">Ask an organizer to add you to see the leaderboard.</span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic">No active tournaments.</p>
<% end %>

<h2 class="text-lg font-semibold mt-6 mb-2">Completed</h2>
<% if @completed_tournaments.any? %>
  <ul class="space-y-2">
    <% @completed_tournaments.each do |t| %>
      <% visible = tournament_leaderboard_visible?(t) %>
      <li class="bg-slate-800 rounded-lg px-4 py-3 opacity-75">
        <% if visible %>
          <%= link_to t.name, t, class: "text-lg font-medium text-blue-300" %>
        <% else %>
          <span class="text-lg font-medium text-slate-200"><%= t.name %></span>
        <% end %>
        <span class="text-xs uppercase tracking-wide text-slate-400 ml-2">Completed</span>
        <% if t.season_tag.present? %>
          <span class="text-sm text-slate-400">— <%= t.season_tag %></span>
        <% end %>
        <% unless visible %>
          <span class="block text-xs text-slate-400 mt-0.5">Ask an organizer to add you to see the leaderboard.</span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic">No completed tournaments yet.</p>
<% end %>
