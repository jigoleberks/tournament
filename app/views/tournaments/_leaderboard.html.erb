<% scope = local_assigns[:viewer_scope] || Leaderboards::ViewerScope.full %>
<% tournament = local_assigns[:tournament] %>
<% blind_active = tournament.present? && tournament.blind?(at: Time.current) %>
<% rows = Leaderboards::PresentationOrder.call(rows: leaderboard, viewer_scope: scope) %>

<div id="leaderboard">
<% if blind_active && scope.visibility != :full %>
  <div id="blind-leaderboard-banner" class="bg-slate-800 rounded-xl p-3 mb-3 text-slate-200 text-sm">
    🔒 Blind leaderboard — full results revealed when the tournament ends at <%= tournament.ends_at.strftime("%b %d · %l:%M %p") %>.
  </div>
<% end %>

<% if tournament&.format_hidden_length? %>
  <% if tournament.hidden_length_target.present? %>
    <div id="hidden-length-banner" class="bg-amber-900 rounded-xl p-3 mb-3 text-amber-100 text-sm">
      🎯 Target was <%= format_length_dual(tournament.hidden_length_target) %> — closest catch wins.
    </div>
  <% elsif tournament.ends_at && tournament.ends_at <= Time.current %>
    <div id="hidden-length-banner" class="bg-slate-800 rounded-xl p-3 mb-3 text-slate-200 text-sm">
      🎯 Tournament ended — rolling target now. Closest catch wins.
    </div>
  <% else %>
    <div id="hidden-length-banner" class="bg-slate-800 rounded-xl p-3 mb-3 text-slate-200 text-sm">
      🎯 Target rolls when the tournament ends at <%= tournament.ends_at.strftime("%b %d · %l:%M %p") %>. Closest catch wins.
    </div>
  <% end %>
<% end %>

<table class="w-full text-base">
  <thead>
    <tr class="text-left text-sm text-slate-300 border-b border-slate-700">
      <th class="px-3 py-2">#</th>
      <th class="px-3 py-2">Entry</th>
      <th class="px-3 py-2"><%= (tournament&.format_big_fish_season? || tournament&.format_hidden_length?) ? "Length" : "Total" %></th>
    </tr>
  </thead>
  <tbody>
    <% rows.each_with_index do |row, i| %>
      <% row_visible = scope.visibility == :full || (scope.visibility == :own_entry_only && row[:entry].id == scope.entry_id) %>
      <tr class="border-t border-slate-700 align-top">
        <td class="px-3 py-3"><%= scope.visibility == :full ? i + 1 : "—" %></td>
        <td class="px-3 py-3">
          <% per_catch = tournament&.format_big_fish_season? || (tournament&.format_hidden_length? && tournament.hidden_length_target.nil?) %>
          <% if per_catch && row[:fish].first %>
            <% f = row[:fish].first %>
            <% url, frame = catch_link_target(tournament: tournament, catch_id: f[:id]) %>
            <div class="font-medium">
              <% if url && row_visible %>
                <%= link_to row[:entry].display_name, url,
                            data: ({ turbo_frame: frame } if frame),
                            class: "text-blue-300 underline-offset-2 hover:underline" %>
              <% else %>
                <%= row[:entry].display_name %>
              <% end %>
              <% if row_visible && f[:approver_name] %>
                <span data-test="approved-check" class="text-green-400 ml-1" aria-label="approved">✓</span>
              <% end %>
            </div>
            <% if row_visible && f[:logged_by_name] %>
              <div class="text-xs text-slate-500 mt-1">logged by <%= f[:logged_by_name] %></div>
            <% end %>
          <% else %>
            <div class="font-medium"><%= row[:entry].display_name %></div>
            <% if row_visible && row[:fish].present? %>
              <div class="text-xs text-slate-400 mt-1 space-y-2">
                <% row[:fish].each do |f| %>
                  <div>
                    <% label = "#{f[:species_name]} · #{format_length_dual(f[:length_inches])}" %>
                    <% url, frame = catch_link_target(tournament: tournament, catch_id: f[:id]) %>
                    <% if url %>
                      <%= link_to label, url,
                                  data: ({ turbo_frame: frame } if frame),
                                  class: "text-blue-300 underline-offset-2 hover:underline" %>
                    <% else %>
                      <span><%= label %></span>
                    <% end %>
                    <% if f[:approver_name] %>
                      <span data-test="approved-check" class="text-green-400 ml-1" aria-label="approved">✓</span>
                    <% end %>
                    <div class="text-slate-500">
                      <%= f[:angler_name] %><%= " · logged by #{f[:logged_by_name]}" if f[:logged_by_name] %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </td>
        <td class="px-3 py-3 font-mono">
          <% if row_visible %>
            <% scoring_value = row[:total] %>
            <% if scoring_value.nil? || scoring_value.zero? %>
              <div>—</div>
            <% else %>
              <% inches_part, cm_part = format_length_parts(scoring_value) %>
              <div><%= inches_part %></div>
              <div><%= cm_part %></div>
              <% if tournament&.format_hidden_length? && tournament.hidden_length_target.present? %>
                <div class="text-xs text-slate-400">
                  <%= format("%.2f", (scoring_value.to_d - tournament.hidden_length_target.to_d).abs) %>" off
                </div>
              <% end %>
            <% end %>
          <% else %>
            <div>—</div>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
