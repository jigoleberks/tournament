<% scope = local_assigns[:viewer_scope] || Leaderboards::ViewerScope.full %>
<% tournament = local_assigns[:tournament] %>
<% blind_active = tournament.present? && tournament.blind?(at: Time.current) %>
<% can_open = tournament.present? && can_open_catches_in?(tournament) %>

<div id="leaderboard">
<% if blind_active && scope.visibility != :full %>
  <div id="blind-leaderboard-banner" class="bg-slate-800 rounded-xl p-3 mb-3 text-slate-200 text-sm">
    🔒 Blind leaderboard — full results revealed when the tournament ends at <%= tournament.ends_at.strftime("%b %d · %l:%M %p") %>.
  </div>
<% end %>

<table class="w-full text-base">
  <thead>
    <tr class="text-left text-sm text-slate-300 border-b border-slate-700">
      <th class="px-3 py-2">#</th>
      <th class="px-3 py-2">Entry</th>
      <th class="px-3 py-2">Total</th>
    </tr>
  </thead>
  <tbody>
    <% leaderboard.each_with_index do |row, i| %>
      <% row_visible = scope.visibility == :full || (scope.visibility == :own_entry_only && row[:entry].id == scope.entry_id) %>
      <tr class="border-t border-slate-700 align-top">
        <td class="px-3 py-3"><%= scope.visibility == :full ? i + 1 : "—" %></td>
        <td class="px-3 py-3">
          <div class="font-medium"><%= row[:entry].display_name %></div>
          <% if row_visible && row[:fish].present? %>
            <div class="text-xs text-slate-400 mt-1 space-y-2">
              <% row[:fish].each do |f| %>
                <div>
                  <% label = "#{f[:species_name]} · #{format_length_dual(f[:length_inches])}" %>
                  <% if can_open %>
                    <%= link_to label, catch_path(f[:id], t: tournament.id),
                                class: "text-blue-300 underline-offset-2 hover:underline" %>
                  <% else %>
                    <span><%= label %></span>
                  <% end %>
                  <% if f[:approver_name] %>
                    <span data-test="approved-check" class="text-green-400 ml-1" aria-label="approved">✓</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </td>
        <td class="px-3 py-3 font-mono">
          <% if row_visible %>
            <% inches_total, cm_total = format_length_parts(row[:total]) %>
            <div><%= inches_total %></div>
            <div><%= cm_total %></div>
          <% else %>
            <div>—</div>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
