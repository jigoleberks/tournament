<h1 class="text-2xl font-semibold mt-4 mb-4">Pre-trip check</h1>

<div data-controller="pre-trip"
     data-pre-trip-active-tournaments-value="<%= @active_tournament_count %>"
     class="bg-slate-800 rounded-xl p-4 my-3">

  <ul class="divide-y divide-slate-700">
    <% [
         ["session",       "Logged in"],
         ["tournaments",   "Tournaments loaded"],
         ["camera",        "Camera"],
         ["microphone",    "Microphone"],
         ["gps",           "GPS"],
         ["clock",         "Clock"],
         ["notifications", "Notifications"],
         ["network",       "Network"],
         ["version",       "App version"]
       ].each do |check, label| %>
      <li data-check="<%= check %>" class="py-3">
        <div class="flex justify-between items-center">
          <span><%= label %></span>
          <span data-pre-trip-target="<%= check %>" class="text-slate-400 text-right">…</span>
        </div>
        <p data-pre-trip-hint class="hidden mt-1 text-xs text-slate-400"></p>
      </li>
    <% end %>
  </ul>

  <button type="button" data-action="pre-trip#runAll"
          class="w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white mt-4">Re-test</button>

  <div class="mt-4 border-t border-slate-700 pt-3">
    <h2 class="text-sm text-slate-400">Troubleshooting</h2>

    <div class="mt-3 space-y-2">
      <button type="button" data-action="pre-trip#updateApp"
              class="w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 mt-2">Update app (clear cache)</button>
      <p class="text-xs text-slate-500">Reloads with a fresh copy if the app is stuck on an old version. Pending catches are kept.</p>

      <p data-pre-trip-target="troubleshootStatus" class="text-sm text-amber-300 min-h-5"></p>
    </div>
  </div>
</div>
