<%= form_with url: judges_tournament_catch_review_path(tournament_id: tournament.id, catch_id: catch.id), local: true do |f| %>
  <%= label_tag :note, "Note (required if disqualifying)" %>
  <%= text_area_tag :note %>
  <% own_catch = current_user.id == catch.user_id %>
  <% unless own_catch %>
    <%= button_tag "Approve", name: "action_kind", value: "approve" %>
  <% end %>
  <%= button_tag "Flag",       name: "action_kind", value: "flag" %>
  <%= button_tag "Disqualify", name: "action_kind", value: "disqualify" %>
  <%= button_tag "Verified at dock", name: "action_kind", value: "dock_verify" %>
  <% if own_catch %>
    <p class="text-xs text-slate-500 mt-1">You can't approve your own catch.</p>
  <% end %>
<% end %>
