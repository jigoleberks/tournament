<h2>Manual override</h2>
<%= form_with url: judges_tournament_catch_manual_override_path(tournament_id: @tournament.id, catch_id: @catch.id), local: true do |f| %>
  <%= label_tag :length_inches, "Override length (in)" %>
  <%= number_field_tag :length_inches, @catch.length_inches, step: 0.25 %>

  <%= label_tag :slot_index, "Force into slot index (optional)" %>
  <%= number_field_tag :slot_index %>

  <%= label_tag :entry_id, "Entry id (optional)" %>
  <%= number_field_tag :entry_id %>

  <%= label_tag :note %>
  <%= text_area_tag :note %>

  <%= submit_tag "Save override" %>
<% end %>
