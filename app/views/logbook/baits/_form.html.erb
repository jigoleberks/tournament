<%= form_with model: [:logbook, @bait], local: true, class: "space-y-4" do |f| %>
  <% if @bait.errors.any? %>
    <div class="bg-red-900/40 border border-red-700 rounded p-3 text-sm text-red-200">
      <%= @bait.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :color, class: "block text-slate-300 mb-1" %>
    <%= f.text_field :color, placeholder: "e.g. orange, blue/pink",
                     class: "w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
  </div>

  <div>
    <%= f.label :weight, class: "block text-slate-300 mb-1" %>
    <%= f.text_field :weight, placeholder: "e.g. 3/8 oz",
                     class: "w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
  </div>

  <div>
    <%= f.label :lure_type, "Lure type", class: "block text-slate-300 mb-1" %>
    <%= f.text_field :lure_type, placeholder: "e.g. fireball, jighead, crankbait",
                     class: "w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
  </div>

  <div>
    <%= f.label :bait_type, "Bait / tipping", class: "block text-slate-300 mb-1" %>
    <%= f.text_field :bait_type, placeholder: "e.g. minnow, jumbo minnow, curly tail plastic",
                     class: "w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
  </div>

  <p class="text-xs text-slate-400">At least one field is required. Whichever you fill in shows up in the bait picker.</p>

  <div class="flex gap-2">
    <%= f.submit (@bait.persisted? ? "Save bait" : "Add bait"),
                  class: "flex-1 h-12 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white font-semibold" %>
    <%= link_to "Cancel", logbook_baits_path,
                class: "flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
  </div>
<% end %>
