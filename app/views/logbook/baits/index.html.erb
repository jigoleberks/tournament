<div class="flex items-center justify-between mt-4 mb-3">
  <h1 class="text-2xl font-semibold">My baits</h1>
  <%= link_to "Back to logbook", logbook_path, class: "text-blue-400 font-medium" %>
</div>

<%= link_to "Add a bait", new_logbook_bait_path,
            class: "block w-full h-12 px-4 mb-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white text-center font-semibold leading-[3rem]" %>

<% if @active_baits.any? %>
  <ul class="space-y-2">
    <% @active_baits.each do |bait| %>
      <li class="bg-slate-800 rounded-lg p-3 flex items-center gap-3">
        <div class="flex-1 min-w-0">
          <div class="font-medium text-slate-100 truncate"><%= bait.display_name %></div>
        </div>
        <%= link_to "Edit", edit_logbook_bait_path(bait),
                    class: "px-3 py-1 bg-slate-700 rounded text-sm font-medium" %>
        <%= button_to "Archive", logbook_bait_path(bait),
                      method: :delete,
                      form: { data: { turbo_confirm: "Archive #{bait.display_name}?" } },
                      class: "px-3 py-1 bg-slate-700 rounded text-sm font-medium" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic">No baits yet. Add one to start tagging catches.</p>
<% end %>

<% if @archived_baits.any? %>
  <h2 class="text-lg font-semibold mt-6 mb-2 text-slate-400">Archived</h2>
  <ul class="space-y-2 opacity-70">
    <% @archived_baits.each do |bait| %>
      <li class="bg-slate-800 rounded-lg p-3">
        <div class="text-slate-300 truncate"><%= bait.display_name %></div>
      </li>
    <% end %>
  </ul>
<% end %>
