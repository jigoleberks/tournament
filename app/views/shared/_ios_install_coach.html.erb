<% is_ios = request.user_agent.to_s.match?(/iPhone|iPad/) %>
<% if is_ios %>
  <div id="ios-install-coach"
       hidden
       class="bg-yellow-500/20 border border-yellow-500/40 text-yellow-100 rounded-lg px-3 py-3 my-2 mx-4 text-sm">
    <p class="font-semibold mb-1">Install this app to your home screen.</p>
    <p class="mb-3">
      In Safari, tap
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="inline w-4 h-4 align-text-bottom" aria-label="Share">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
        <polyline points="16 6 12 2 8 6"/>
        <line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
      Share, then <em>Add to Home Screen</em>. Push notifications and reliable
      catch uploads only work once installed.
    </p>
    <button type="button"
            onclick="this.closest('#ios-install-coach').hidden=true;try{localStorage.setItem('ios-coach-dismissed','1')}catch(_){}"
            class="h-8 px-3 rounded-lg bg-yellow-500/30 active:bg-yellow-500/50 text-yellow-100 text-sm font-medium">
      Got it
    </button>
  </div>
  <script>
    (function() {
      var el = document.getElementById("ios-install-coach");
      if (!el) return;
      var standalone = false, dismissed = false;
      try {
        standalone = window.matchMedia("(display-mode: standalone)").matches;
        dismissed = !!localStorage.getItem("ios-coach-dismissed");
      } catch (_) {}
      if (!standalone && !dismissed) el.hidden = false;
    })();
  </script>
<% end %>
