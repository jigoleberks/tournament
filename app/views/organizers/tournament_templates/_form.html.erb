<%= form_with model: [:organizers, @template], local: true, class: "space-y-4" do |f| %>
  <% if @template.errors.any? %>
    <ul class="text-red-300 text-sm bg-red-900/40 border border-red-800 rounded-lg p-3 space-y-1">
      <% @template.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
    </ul>
  <% end %>

  <div class="bg-slate-800 rounded-xl p-4 space-y-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-300 mb-1" %>
      <%= f.text_field :name,
                       class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>
    </div>

    <div>
      <%= f.label :mode, class: "block text-sm font-medium text-slate-300 mb-1" %>
      <%= f.select :mode, TournamentTemplate.modes.keys, {},
                   class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>
    </div>

    <div>
      <%= f.label :default_duration_days, "Default duration (days)",
                  class: "block text-sm font-medium text-slate-300 mb-1" %>
      <%= f.number_field :default_duration_days,
                         class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>
    </div>

    <label class="flex items-center gap-3 mt-2">
      <%= f.check_box :awards_season_points, class: "h-5 w-5" %>
      <span class="text-slate-200">Awards season points</span>
    </label>
    <p class="text-xs text-slate-500 -mt-2">When on, tournaments cloned from this template are points-eligible by default.</p>

    <label class="flex items-center gap-3 mt-2">
      <%= f.check_box :blind_leaderboard, class: "h-5 w-5" %>
      <span class="text-slate-200">Blind leaderboard</span>
    </label>
    <p class="text-xs text-slate-500 -mt-2">
      When on, tournaments cloned from this template start with blind leaderboard mode enabled.
    </p>
  </div>

  <div class="bg-slate-800 rounded-xl p-4 space-y-4">
    <h3 class="text-lg font-semibold">Weekly schedule (optional)</h3>
    <p class="text-sm text-slate-400">Set a weekday and time window so cloning this template schedules the next occurrence automatically. Leave all three blank to keep ad-hoc cloning.</p>

    <div>
      <%= f.label :default_weekday, "Day of week",
                  class: "block text-sm font-medium text-slate-300 mb-1" %>
      <%= f.select :default_weekday,
                   Date::DAYNAMES.each_with_index.map { |n, i| [n, i] },
                   { include_blank: "—" },
                   class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>
    </div>

    <div>
      <%= f.label :default_start_time, "Start time",
                  class: "block text-sm font-medium text-slate-300 mb-1" %>
      <%= f.time_field :default_start_time,
                       class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>
    </div>

    <div>
      <%= f.label :default_end_time, "End time",
                  class: "block text-sm font-medium text-slate-300 mb-1" %>
      <%= f.time_field :default_end_time,
                       class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>
    </div>
  </div>

  <div class="bg-slate-800 rounded-xl p-4 space-y-3">
    <h3 class="text-lg font-semibold">Scoring slots</h3>
    <p class="text-sm text-slate-400">Pick a species and how many of that fish counts. Blank rows are ignored.</p>

    <%= f.fields_for :tournament_template_scoring_slots do |sf| %>
      <div class="bg-slate-900 rounded-lg p-3 space-y-2 border border-slate-700">
        <label class="block text-sm text-slate-400">Species</label>
        <%= sf.collection_select :species_id, current_user.club.species.order(:name), :id, :name,
                                 { include_blank: "—" },
                                 class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>

        <label class="block text-sm text-slate-400 mt-2">Slots</label>
        <%= sf.number_field :slot_count, min: 1, value: sf.object.slot_count || 1,
                            class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base" %>

        <% if sf.object.persisted? %>
          <label class="flex items-center gap-2 text-sm text-slate-400 mt-2">
            <%= sf.check_box :_destroy, class: "h-5 w-5" %>
            Remove this slot
          </label>
        <% end %>
      </div>
    <% end %>

    <p class="text-xs text-slate-500 italic">
      Save the template for another empty row to appear on the edit page.
    </p>
  </div>

  <%= f.submit class: "w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white" %>
<% end %>
