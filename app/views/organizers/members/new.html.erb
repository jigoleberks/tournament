<h1 class="text-2xl font-semibold mt-4 mb-4">Invite member</h1>

<%= form_with model: @user, url: organizers_members_path, scope: :user, local: true,
              class: "bg-slate-800 rounded-lg p-4 space-y-4" do |f| %>
  <% if @user.errors.any? %>
    <ul class="text-red-400 text-sm">
      <% @user.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-300 mb-1" %>
    <%= f.text_field :name,
                     class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-300 mb-1" %>
    <%= f.email_field :email,
                      class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700" %>
  </div>

  <div>
    <%= f.label :role, class: "block text-sm font-medium text-slate-300 mb-1" %>
    <%= f.select :role, ClubMembership.roles.keys,
                 {},
                 class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700" %>
  </div>

  <%= f.submit "Send invite",
               class: "w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white" %>
<% end %>
