<% content_for :head do %>
  <%# Shared club laptop: after sign-out, Back must not replay member emails /
      live sign-in codes from Turbo's snapshot cache (restoration visits never
      hit the server). Scoped here rather than the whole application layout so
      normal member pages keep instant back-nav. %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<h1 class="text-2xl font-semibold mt-4 mb-4">Members</h1>
<%= link_to "Invite", new_organizers_member_path,
            class: "inline-block h-12 px-4 leading-[3rem] rounded-lg bg-blue-600 text-white" %>

<ul class="mt-4 space-y-2">
  <% @users.each do |u| %>
    <li class="bg-slate-800 rounded-lg px-4 py-3 flex items-center justify-between gap-3">
      <div>
        <strong><%= u.name %></strong>
        — <%= u.club_memberships.find { |m| m.club_id == current_club.id }&.role %>
        <% if u.deactivated? %>
          <span class="text-sm text-amber-400">— deactivated</span>
        <% end %>
        <span class="text-sm text-slate-400">— <%= u.email %></span>
      </div>
      <div class="flex items-center gap-2">
        <% if u == current_user %>
          <span class="text-sm text-slate-500">you</span>
        <% elsif u.deactivated? %>
          <%= button_to "Reactivate",
                        reactivate_organizers_member_path(u),
                        method: :post,
                        class: "h-10 px-3 rounded bg-emerald-600 active:bg-emerald-700 text-white" %>
        <% else %>
          <%= button_to "Issue code",
                        issue_code_organizers_member_path(u),
                        method: :post,
                        data: { turbo_confirm: "Generate a one-time sign-in code for #{u.name}? Valid 10 minutes." },
                        class: "h-10 px-3 rounded bg-slate-700 active:bg-slate-600 text-white" %>
          <%= button_to "Deactivate",
                        organizers_member_path(u),
                        method: :delete,
                        data: { turbo_confirm: "Deactivate #{u.name}? They'll be hidden from new entries but past results stay." },
                        class: "h-10 px-3 rounded bg-red-600 active:bg-red-700 text-white" %>
        <% end %>
      </div>
    </li>
  <% end %>
</ul>
