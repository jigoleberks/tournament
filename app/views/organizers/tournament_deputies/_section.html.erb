<h3 class="text-lg font-semibold mt-6 mb-2">Deputies</h3>
<p class="text-sm text-slate-400 mb-2">
  A deputy gets full organizer access until this tournament starts, then goes back to being a regular member.
</p>

<% if @tournament.tournament_deputies.any? %>
  <ul class="space-y-2 mb-3">
    <% @tournament.tournament_deputies.includes(:user).each do |td| %>
      <li class="bg-slate-800 rounded-lg px-3 py-2 flex items-center justify-between">
        <span><%= td.user.name %></span>
        <%= button_to "Remove",
                      organizers_tournament_tournament_deputy_path(tournament_id: @tournament.id, id: td.id),
                      method: :delete,
                      data: { turbo_confirm: "Remove #{td.user.name} as deputy?" },
                      class: "h-10 px-3 rounded bg-red-600 active:bg-red-700 text-white" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic mb-3">No deputies yet.</p>
<% end %>

<% if @tournament.started? %>
  <p class="text-slate-400 italic mb-3">This tournament has started — deputy access has ended.</p>
<% else %>
  <% available = current_club.members.active.where.not(id: @tournament.deputy_users.pluck(:id)).order(:name) %>
  <% if available.any? %>
    <%= form_with url: organizers_tournament_tournament_deputies_path(tournament_id: @tournament.id),
                  local: true,
                  class: "bg-slate-800 rounded-lg p-3 space-y-2" do %>
      <%= select_tag "tournament_deputy[user_id]",
                     options_from_collection_for_select(available, :id, :name),
                     prompt: "Select member…",
                     class: "w-full h-11 px-3 rounded bg-slate-900 border border-slate-700 text-slate-100" %>
      <%= submit_tag "Add deputy",
                     class: "w-full h-11 rounded bg-blue-600 active:bg-blue-700 text-white font-semibold cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>
