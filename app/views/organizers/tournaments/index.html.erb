<h1 class="text-2xl font-semibold mt-4 mb-4">Organizer</h1>

<nav class="flex flex-wrap gap-2 mb-6">
  <%= link_to "Members", organizers_members_path,
              class: "h-12 px-4 leading-[3rem] rounded-lg bg-slate-700 text-slate-100" %>
  <%= link_to "Templates", organizers_tournament_templates_path,
              class: "h-12 px-4 leading-[3rem] rounded-lg bg-slate-700 text-slate-100" %>
  <%= link_to "Catch history", organizers_catches_path,
              class: "h-12 px-4 leading-[3rem] rounded-lg bg-slate-700 text-slate-100" %>
  <%= link_to "New tournament", new_organizers_tournament_path,
              class: "h-12 px-4 leading-[3rem] rounded-lg bg-blue-600 text-white" %>
</nav>

<h2 class="text-lg font-semibold mt-6 mb-2">Active tournaments</h2>
<% if @active_tournaments.any? %>
  <ul class="space-y-2">
    <% @active_tournaments.each do |t| %>
      <li class="relative bg-slate-800 rounded-lg p-4 hover:bg-slate-700">
        <div class="mb-3">
          <%= link_to edit_organizers_tournament_path(t), class: "text-blue-300 font-medium text-lg" do %>
            <span class="absolute inset-0 rounded-lg" aria-hidden="true"></span>
            <span class="relative"><%= t.name %></span>
          <% end %>
          <span class="relative text-sm text-slate-400">— <%= t.starts_at.strftime("%b %d") %></span>
        </div>
        <%= button_to "Delete", organizers_tournament_path(t),
                      method: :delete,
                      data: { turbo_confirm: "Delete '#{t.name}'? This removes the tournament, its entries, and all placements. This cannot be undone." },
                      class: "relative h-12 px-4 rounded-lg bg-red-600 active:bg-red-700 text-white" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic">No active tournaments.</p>
<% end %>

