<%# Local: f (form builder), record (Tournament or TournamentTemplate) %>
<% locked = record.respond_to?(:starts_at) && record.persisted? && record.starts_at && record.starts_at <= Time.current %>
<% labels = { "standard" => "Standard", "big_fish_season" => "Big Fish Season", "hidden_length" => "Hidden Length", "biggest_vs_smallest" => "Biggest vs Smallest", "fish_train" => "Fish Train", "tagged" => "Tagged Walleye", "smallest_fish" => "Smallest Fish", "pro_walleye" => "Pro Walleye", "bingo" => "Bingo", "progressive_length" => "Progressive Length", "beat_the_average" => "Beat the Average", "random_bag" => "Random Bag" } %>
<% descriptions = {
  "standard" => "Per-species scoring slots. Each member or team logs their top fish per species; the leaderboard ranks by total length.",
  "big_fish_season" => "Ranks members by their single biggest fish (tiebroken by next-biggest). Solo only, one species.",
  "hidden_length" => "Random target length (12–22\") is rolled when the tournament ends. Closest catch wins. Solo or team, one species.",
  "biggest_vs_smallest" => "Score is your biggest catch's length minus your smallest catch's length. Largest spread wins. Solo or team, one species. Need at least 2 catches to qualify.",
  "fish_train" => "Catch a configured train of species in order. Each new car locks the previous one. Score is the sum of car lengths. Solo or team, 1–3 species pool, 3–6 ordered cars.",
  "tagged" => "Each Tagged Walleye catch is one ticket in a random draw. Organizer triggers the draw after the tournament ends. Solo only, locked to the Tagged Walleye species.",
  "smallest_fish" => "Per-species scoring slots, but smallest counts. Each member or team logs their smallest fish per species; the leaderboard ranks by lowest total length — smallest total wins.",
  "pro_walleye" => "Pro Walleye slot limit (Saskatchewan). Walleye only, five-fish basket: at most 2 fish over 55 cm, the rest 55 cm and under. Highest total length wins. Solo or team.",
  "bingo" => "5×5 bingo card of catch challenges (species, length, time of day). Squares stamp in as you log qualifying fish. First to blackout wins; else most completed lines, then most squares. Shared card, no scoring slots. Best run as a fixed 6–9 PM league night.",
  "progressive_length" => "Every fish must beat your previous fish. A smaller fish is ignored — it never breaks your run. Most up-sizes wins; ties go to whoever got there first. Solo or team, one species.",
  "beat_the_average" => "Every logged fish counts toward a hidden running average. During play, catches are hidden between teams — you see only your own team's fish and your team's average. When the tournament ends, the average of all logged fish is revealed and the single catch closest to it wins. Solo or team, one or more species.",
  "random_bag" => "Each team gets its own random target length (70–100\" by default, set per tournament) revealed at the start. Build the bag of up to 5 fish whose total length lands closest to your target — over or under. Blind during play: you see only your own target and bag. Solo or team, one or more species."
} %>
<% current_format = record.format.presence || "standard" %>
<div>
  <%= f.label :format, "Format", class: "block text-sm font-medium text-slate-300 mb-1" %>
  <%= f.select :format,
               record.class.formats.keys.map { |k| [labels[k], k] },
               {},
               class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base",
               data: { tournament_format_target: "format", action: "change->tournament-format#sync" },
               disabled: locked %>
  <% if locked %>
    <%= f.hidden_field :format %>
  <% end %>
  <p class="text-xs text-slate-500 mt-1"
     data-tournament-format-target="formatDescription"
     data-standard-text="<%= descriptions["standard"] %>"
     data-big-fish-season-text="<%= descriptions["big_fish_season"] %>"
     data-hidden-length-text="<%= descriptions["hidden_length"] %>"
     data-biggest-vs-smallest-text="<%= descriptions["biggest_vs_smallest"] %>"
     data-fish-train-text="<%= descriptions["fish_train"] %>"
     data-tagged-text="<%= descriptions["tagged"] %>"
     data-smallest-fish-text="<%= descriptions["smallest_fish"] %>"
     data-pro-walleye-text="<%= descriptions["pro_walleye"] %>"
     data-bingo-text="<%= descriptions["bingo"] %>"
     data-progressive-length-text="<%= descriptions["progressive_length"] %>"
     data-beat-the-average-text="<%= descriptions["beat_the_average"] %>"
     data-random-bag-text="<%= descriptions["random_bag"] %>">
    <%= descriptions[current_format] %>
  </p>
  <% if locked %>
    <p class="text-xs text-slate-500 mt-1"><strong>Locked once the tournament starts.</strong></p>
  <% end %>
</div>
