<section data-controller="pending-catches" class="bg-slate-800 rounded-xl p-4 my-3">
  <h2 class="text-lg font-semibold mb-2">Pending sync</h2>
  <p data-pending-catches-target="empty" hidden class="text-slate-400 text-sm">None — you're all caught up.</p>
  <ul data-pending-catches-target="list" class="text-sm text-slate-300"></ul>
</section>

<div class="my-4">
  <h1 class="text-2xl font-bold mb-1"><%= ENV.fetch("APP_NAME", "Tournament") %></h1>
  <p class="text-slate-400 mb-4">Hello, <%= current_user.name %>.</p>
  <%= link_to "Log Catch", new_catch_path, class: "block w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white text-center leading-[3.5rem]" %>
</div>

<% active_tournaments = Tournaments::ActiveForUser.call(user: current_user) %>
<% if active_tournaments.any? %>
  <div class="bg-slate-800 rounded-xl p-4 my-3">
    <h2 class="text-lg font-semibold mb-2">Your tournaments</h2>
    <% active_tournaments.each do |t| %>
      <%= link_to t.name, t, class: "block py-3 px-2 rounded hover:bg-slate-700 text-slate-100 border-b border-slate-700 last:border-0" %>
    <% end %>
  </div>
<% end %>

<% other_tournaments = current_user.club.tournaments.where.not(id: active_tournaments.map(&:id)).order(starts_at: :desc) %>
<% if other_tournaments.any? %>
  <div class="bg-slate-800 rounded-xl p-4 my-3">
    <h2 class="text-lg font-semibold mb-2">Other tournaments in your club</h2>
    <% other_tournaments.each do |t| %>
      <%= link_to t.name, t, class: "block py-3 px-2 rounded hover:bg-slate-700 text-slate-100 border-b border-slate-700 last:border-0" %>
    <% end %>
  </div>
<% end %>

<% current_user.tournament_judges.includes(:tournament).each do |tj| %>
  <% if tj.tournament.active? %>
    <div class="bg-slate-800 rounded-xl p-4 my-3">
      <p class="text-slate-300">You're judging <strong class="text-slate-100"><%= tj.tournament.name %></strong> — no fishing in this one.</p>
    </div>
  <% end %>
<% end %>

<%= form_with url: me_path, method: :patch, local: true,
              class: "bg-slate-800 rounded-xl p-4 my-3" do |f| %>
  <p class="text-slate-300 mb-2 font-medium">My length unit</p>
  <div class="flex gap-2">
    <% User::LENGTH_UNITS.each do |unit| %>
      <label class="flex-1">
        <%= radio_button_tag "user[length_unit]", unit, current_user.length_unit == unit, class: "sr-only peer" %>
        <span class="block w-full h-12 leading-[3rem] text-center rounded-lg bg-slate-700 peer-checked:bg-blue-600 text-slate-100 peer-checked:text-white cursor-pointer">
          <%= unit == "inches" ? "Inches" : "Centimeters" %>
        </span>
      </label>
    <% end %>
  </div>
  <%= f.submit "Save",
               class: "mt-3 w-full h-10 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100" %>
<% end %>

<div class="my-3">
  <%= link_to "Pre-trip check", pre_trip_path, class: "block w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
</div>

<% if current_user.organizer? %>
  <div class="my-3">
    <%= link_to "Organizer", organizers_tournaments_path,
                class: "block w-full h-12 px-4 rounded-lg bg-amber-600 active:bg-amber-700 text-white text-center leading-[3rem] font-semibold" %>
  </div>
<% end %>

<section data-controller="push-register" class="bg-slate-800 rounded-xl p-4 my-3">
  <p class="text-slate-300 mb-3">Notifications: <span data-push-register-target="status" class="text-slate-100 font-medium">…</span></p>
  <div class="flex gap-2">
    <button type="button" data-action="push-register#enable"
            class="flex-1 h-12 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white">Enable</button>
    <button type="button" data-action="push-register#disable"
            class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Disable</button>
  </div>
</section>
