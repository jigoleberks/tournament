<section data-controller="pending-catches" class="bg-slate-800 rounded-xl p-4 my-3">
  <div data-pending-catches-target="failedSection" hidden class="mb-3 pb-3 border-b border-slate-700">
    <h2 class="text-lg font-semibold mb-2 text-amber-400">Sync issues</h2>
    <ul data-pending-catches-target="failedList" class="text-sm text-slate-300 space-y-1"></ul>
    <p class="text-xs text-slate-400 mt-2">Tap Retry to try syncing again. If it keeps failing, talk to your organizer.</p>
  </div>
  <h2 class="text-lg font-semibold mb-2">Pending sync</h2>
  <p data-pending-catches-target="empty" hidden class="text-slate-400 text-sm">None — you're all caught up.</p>
  <ul data-pending-catches-target="list" class="text-sm text-slate-300"></ul>
</section>

<div class="my-4">
  <h1 class="text-2xl font-bold mb-1"><%= ENV.fetch("APP_NAME", "Tournament") %></h1>
  <p class="text-slate-400 mb-4">Hello, <%= current_user.name %>.</p>
  <%= link_to "Log Catch", new_catch_path, class: "block w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white text-center leading-[3.5rem]" %>
  <div class="grid grid-cols-2 gap-2 mt-2">
    <%= link_to "My catches", catches_path, class: "h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
    <%= link_to "Fishing map", map_catches_path, class: "h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
  </div>
</div>

<% active_tournaments = Tournaments::ActiveForUser.call(user: current_user) %>
<% if active_tournaments.any? %>
  <div class="bg-slate-800 rounded-xl p-4 my-3">
    <h2 class="text-lg font-semibold mb-2">Your tournaments</h2>
    <% active_tournaments.each do |t| %>
      <%= link_to t, class: "block py-3 px-2 rounded hover:bg-slate-700 text-slate-100 border-b border-slate-700 last:border-0" do %>
        <span class="block"><%= t.name %></span>
        <% if (window = tournament_window(t)) %>
          <span class="block text-xs text-slate-400 mt-0.5"><%= window %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>

<% other_tournaments = current_club.tournaments.where.not(id: active_tournaments.map(&:id)).order(starts_at: :desc) %>
<% other_active, other_completed = other_tournaments.partition { |t| !t.ended? } %>
<% recent_completed, archived_completed = other_completed.partition { |t| t.ends_at >= 24.hours.ago } %>
<% if other_active.any? %>
  <div class="bg-slate-800 rounded-xl p-4 my-3">
    <h2 class="text-lg font-semibold mb-2">Other tournaments in your club</h2>
    <% other_active.each do |t| %>
      <%= link_to t, class: "block py-3 px-2 rounded hover:bg-slate-700 text-slate-100 border-b border-slate-700 last:border-0" do %>
        <span class="block"><%= t.name %></span>
        <% if (window = tournament_window(t)) %>
          <span class="block text-xs text-slate-400 mt-0.5"><%= window %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>

<% if recent_completed.any? || archived_completed.any? %>
  <div class="bg-slate-800 rounded-xl p-4 my-3">
    <h2 class="text-lg font-semibold mb-2">Completed tournaments</h2>
    <% recent_completed.each do |t| %>
      <%= link_to t, class: "block py-3 px-2 rounded hover:bg-slate-700 text-slate-100 border-b border-slate-700 last:border-0 opacity-75" do %>
        <span class="block"><%= t.name %></span>
        <% if (window = tournament_window(t)) %>
          <span class="block text-xs text-slate-400 mt-0.5"><%= window %></span>
        <% end %>
      <% end %>
    <% end %>
    <% if archived_completed.any? %>
      <%= link_to "View older completed tournaments", archived_tournaments_path,
                  class: "block mt-3 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
    <% end %>
  </div>
<% end %>

<%
  current_tag = SeasonPoints::CurrentSeasonTag.call(club: current_club)
  current_standings = current_tag ? SeasonPoints::Standings.call(club: current_club, season_tag: current_tag) : []
%>
<% if current_tag %>
  <%= render "home/season_points_top", season_tag: current_tag, standings: current_standings %>
<% end %>

<% current_user.tournament_judges.includes(:tournament).each do |tj| %>
  <% if tj.tournament.active? %>
    <div class="bg-slate-800 rounded-xl p-4 my-3">
      <p class="text-slate-300">You're judging <strong class="text-slate-100"><%= tj.tournament.name %></strong> — no fishing in this one.</p>
    </div>
  <% end %>
<% end %>

<div class="my-3">
  <%= link_to "Pre-trip check", pre_trip_path, class: "block w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
</div>

<% if (rev = current_club&.current_rules_revision) %>
  <div class="my-3">
    <%= link_to "Rules (#{rev.created_at.to_date.strftime('%b %-d, %Y')})",
                rules_path,
                class: "block w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
  </div>
<% end %>

<% if ENV["MERCH_URL"].present? %>
  <div class="my-3">
    <%= link_to "Merch", ENV["MERCH_URL"],
                target: "_blank",
                rel: "noopener noreferrer",
                class: "block w-full h-12 px-4 rounded-lg bg-emerald-600 active:bg-emerald-700 text-white text-center leading-[3rem]" %>
  </div>
<% end %>

<% if current_user.organizer_in?(current_club) %>
  <div class="my-3">
    <%= link_to "Organizer", organizers_tournaments_path,
                class: "block w-full h-12 px-4 rounded-lg bg-amber-600 active:bg-amber-700 text-white text-center leading-[3rem] font-semibold" %>
  </div>
<% end %>

<section data-controller="push-register" class="bg-slate-800 rounded-xl p-4 my-3">
  <p class="text-slate-300 mb-3">Notifications: <span data-push-register-target="status" class="text-slate-100 font-medium">…</span></p>
  <div class="flex gap-2">
    <button type="button" data-action="push-register#enable"
            data-push-register-target="enableButton"
            class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Enable</button>
    <button type="button" data-action="push-register#disable"
            class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Disable</button>
  </div>
</section>
