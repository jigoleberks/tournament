<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-3xl font-bold">Edit Tournament</h1>
    <p class="text-slate-400 mt-1"><%= @tournament.name %></p>
  </div>
  <%= link_to "Back to Tournaments", admin_tournaments_path, class: "text-slate-400 hover:text-white transition-colors" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
  <div class="lg:col-span-2">
    <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
      <div class="p-6 border-b border-slate-700 bg-slate-700/30">
        <h2 class="text-lg font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
          </svg>
          Tournament Details
        </h2>
      </div>
      <div class="p-6">
        <%= render "form" %>
      </div>
    </div>

    <div class="mt-8 bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
      <div class="p-6 border-b border-slate-700 bg-slate-700/30">
        <h2 class="text-lg font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
          </svg>
          Catch History
        </h2>
      </div>
      <div class="p-6">
        <%= render "admin/catches/section" %>
      </div>
    </div>
  </div>

  <div class="space-y-8">
    <% if @tournament.format_tagged? && @tournament.drawn_at.present? %>
      <div class="bg-slate-800 rounded-xl border border-amber-700/40 overflow-hidden shadow-xl">
        <div class="p-6 border-b border-slate-700 bg-amber-900/20">
          <h2 class="text-lg font-semibold flex items-center gap-2 text-amber-200">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-amber-300">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.354a15.998 15.998 0 01-3 0M12 2.25a.75.75 0 11.75.75A.75.75 0 0112 2.25zM4.5 9.75A7.5 7.5 0 0112 2.25a7.5 7.5 0 017.5 7.5c0 2.43-1.155 4.59-2.945 5.957L16 17.25H8l-.555-1.543A7.477 7.477 0 014.5 9.75z" />
            </svg>
            Draw — re-roll override
          </h2>
        </div>
        <div class="p-6 space-y-3 text-sm">
          <% winner_catch = @tournament.drawn_winning_placement&.catch %>
          <% if winner_catch %>
            <p class="text-slate-300">
              Current winner: <span class="text-amber-200 font-semibold"><%= winner_catch.user.name %></span>
              &mdash; tag <span class="font-mono text-amber-200"><%= winner_catch.tag_number %></span>
            </p>
            <p class="text-xs text-slate-500">
              Drawn <%= l(@tournament.drawn_at, format: :short) %>
              <% if @tournament.drawn_by_user %>by <%= @tournament.drawn_by_user.name %><% end %>.
            </p>
          <% end %>
          <p class="text-xs text-slate-400">
            Re-rolling overwrites the current winner. Use only if the winning catch was later DQ'd or otherwise invalidated.
          </p>
          <%= button_to "Re-draw winner",
                        draw_organizers_tournament_path(@tournament, force: 1),
                        method: :post,
                        data: { turbo_confirm: "Re-roll the draw? The current winner will be replaced." },
                        class: "inline-flex h-10 px-4 items-center justify-center rounded-lg bg-amber-600 hover:bg-amber-500 text-white font-semibold" %>
        </div>
      </div>
    <% end %>

    <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
      <div class="p-6 border-b border-slate-700 bg-slate-700/30">
        <h2 class="text-lg font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.998 5.998 0 00-5.484-5.845M12 13a4.5 4.5 0 004.5-4.5V21m-4.5-4.5V21m4.5-4.5V21M12 13a4.5 4.5 0 01-4.5-4.5V21m4.5-4.5V21m-4.5-4.5V21" />
          </svg>
          Entries
        </h2>
      </div>
      <div class="p-6">
        <%= render "admin/tournament_entries/section" %>
      </div>
    </div>

    <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
      <div class="p-6 border-b border-slate-700 bg-slate-700/30">
        <h2 class="text-lg font-semibold flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
          </svg>
          Judges
        </h2>
      </div>
      <div class="p-6">
        <%= render "admin/tournament_judges/section" %>
      </div>
    </div>
  </div>
</div>
