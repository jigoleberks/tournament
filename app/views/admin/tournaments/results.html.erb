<% content_for :title, "#{@tournament.name} — Results" %>
<header class="mb-6 border-b border-slate-300 pb-4">
  <h1 class="text-2xl font-bold"><%= @tournament.name %></h1>
  <p class="text-sm text-slate-600 mt-1">
    <%= @tournament.club.name %>
    <% if @tournament.starts_at %> · <%= @tournament.starts_at.strftime("%b %d, %Y") %><% end %>
    <% if @tournament.ends_at %> – <%= @tournament.ends_at.strftime("%b %d, %Y") %><% end %>
  </p>
</header>

<% rows = Leaderboards::PresentationOrder.call(rows: @leaderboard, viewer_scope: Leaderboards::ViewerScope.full) %>
<% if rows.empty? %>
  <p class="text-slate-500 italic">No entries.</p>
<% else %>
  <table class="w-full text-left border-collapse">
    <thead>
      <tr class="border-b border-slate-400 text-sm uppercase tracking-wide text-slate-600">
        <th class="py-2 pr-3 w-10">#</th>
        <th class="py-2 pr-3"><%= @tournament.mode_team? ? "Team" : "Angler" %></th>
        <th class="py-2">Score</th>
      </tr>
    </thead>
    <tbody>
      <% rows.each_with_index do |row, i| %>
        <tr class="border-b border-slate-200 align-top">
          <td class="py-2 pr-3"><%= i + 1 %></td>
          <td class="py-2 pr-3"><%= row[:entry].display_name %></td>
          <td class="py-2"><%= leaderboard_score_label(row, @tournament) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
