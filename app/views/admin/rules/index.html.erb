<h1 class="text-2xl font-bold mb-6 text-white">Club rules</h1>

<section class="mb-8 bg-slate-800 rounded-xl p-4 border border-slate-700">
  <h2 class="text-lg font-semibold mb-3 text-white">Active season</h2>
  <p class="text-slate-400 text-sm mb-3">
    Members see whichever season is active. Switching does not modify any revision.
  </p>
  <div class="flex gap-2">
    <% %w[open_water ice].each do |s| %>
      <% active = current_club.active_rules_season == s %>
      <%= button_to s.humanize, set_active_season_admin_rules_path,
                    params: { season: s }, method: :post,
                    class: "px-4 py-2 rounded-lg text-sm font-medium #{active ? 'bg-blue-600 text-white' : 'bg-slate-700 text-slate-200 hover:bg-slate-600'}" %>
    <% end %>
  </div>
</section>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <% { open_water: @open_water_revision, ice: @ice_revision }.each do |season, rev| %>
    <section class="bg-slate-800 rounded-xl p-4 border border-slate-700">
      <h2 class="text-xl font-semibold text-white mb-2"><%= season.to_s.humanize %> rules</h2>
      <% if rev %>
        <p class="text-xs text-slate-400 mb-3">
          Last edited <%= rev.created_at.to_date.strftime("%b %-d, %Y") %> by <%= rev.edited_by_user.name %>
        </p>
        <div class="prose prose-invert max-w-none text-slate-100 mb-4
                    [&_a]:text-blue-300 [&_a]:underline [&_a]:underline-offset-2
                    [&_h1]:text-xl [&_h1]:font-semibold [&_h1]:mt-6 [&_h1]:mb-2
                    [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:mt-5 [&_h2]:mb-2
                    [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5
                    [&_p]:my-2 [&_li]:my-1
                    [&_code]:bg-slate-800 [&_code]:px-1 [&_code]:rounded
                    [&_pre]:bg-slate-800 [&_pre]:p-3 [&_pre]:rounded">
          <%= render_markdown(rev.body) %>
        </div>
      <% else %>
        <p class="text-slate-400 text-sm italic mb-4">No revisions yet.</p>
      <% end %>
      <div class="flex gap-2">
        <%= link_to "Edit (new revision)", new_admin_rule_path(season: season),
                    class: "px-3 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700" %>
        <%= link_to "View history", history_admin_rules_path(season: season),
                    class: "px-3 py-2 rounded-lg bg-slate-700 text-slate-100 text-sm font-medium hover:bg-slate-600" %>
      </div>
    </section>
  <% end %>
</div>
