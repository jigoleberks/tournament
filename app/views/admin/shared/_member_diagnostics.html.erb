<%# locals: (user:) %>
<% device = current_device(user) %>
<% build  = current_app_build(user) %>
<div class="mt-8 bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
  <div class="p-6 border-b border-slate-700 bg-slate-700/30">
    <h2 class="text-lg font-semibold">Diagnostics</h2>
    <p class="text-sm text-slate-400 mt-1">Support info — populates as the member uses the app.</p>
  </div>

  <div class="p-6 space-y-4 text-sm">
    <div class="flex justify-between gap-4">
      <span class="text-slate-400">Device / browser</span>
      <span class="text-slate-100 text-right">
        <%= device.summary %>
        <% unless device.supported?.nil? %>
          <span class="ml-2 px-2 py-0.5 rounded text-xs <%= device.supported? ? "bg-green-900/50 text-green-300" : "bg-red-900/50 text-red-300" %>">
            <%= device.supported? ? "supported" : "too old" %>
          </span>
        <% end %>
      </span>
    </div>

    <div class="flex justify-between gap-4">
      <span class="text-slate-400">App build</span>
      <span class="text-slate-100 text-right">
        <%= build.presence || "—" %>
        <% if app_build_stale?(build) %>
          <span class="ml-2 px-2 py-0.5 rounded text-xs bg-amber-900/50 text-amber-300">stale</span>
        <% end %>
      </span>
    </div>

    <div class="flex justify-between gap-4">
      <span class="text-slate-400">Last seen</span>
      <span class="text-slate-100"><%= user.last_seen_at ? "#{time_ago_in_words(user.last_seen_at)} ago" : "never" %></span>
    </div>

    <div class="flex justify-between gap-4">
      <span class="text-slate-400">Push subscriptions</span>
      <span class="text-slate-100 text-right">
        <% subs = user.push_subscriptions.to_a %>
        <% if subs.any? %>
          <%= pluralize(subs.count, "device") %>
          <% if subs.any? { |s| s.muted_until && s.muted_until > Time.current } %>
            <span class="ml-1 text-amber-300">(muted)</span>
          <% end %>
        <% else %>
          none
        <% end %>
      </span>
    </div>

    <% events = user.user_events.recent.limit(50).to_a %>
    <% if events.any? %>
      <details class="mt-2">
        <summary class="cursor-pointer text-slate-400 hover:text-white">Recent activity (<%= events.size %>)</summary>
        <ul class="mt-3 space-y-2">
          <% events.each do |ev| %>
            <li class="flex justify-between gap-4 border-t border-slate-700/60 pt-2">
              <span class="text-slate-200"><%= user_event_label(ev) %></span>
              <span class="text-slate-500 text-xs text-right">
                <%= time_ago_in_words(ev.created_at) %> ago
                <% if ev.app_build.present? %><br><span class="text-slate-600"><%= ev.app_build %></span><% end %>
              </span>
            </li>
          <% end %>
        </ul>
      </details>
    <% end %>
  </div>
</div>
