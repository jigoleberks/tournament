<% locked = @tournament.started? %>

<% if locked %>
  <div class="mb-6 bg-slate-900/50 rounded-lg p-4 border border-slate-700 text-slate-400 text-sm italic">
    Tournament has started — entries are locked.
  </div>
<% else %>
  <% available = current_club.members.active.order(:name) %>
  <%= form_with url: admin_tournament_tournament_entries_path(tournament_id: @tournament.id), local: true,
                class: "mb-8 space-y-4" do |f| %>

    <div class="bg-slate-900 rounded-xl border border-slate-700 overflow-hidden">
      <div class="p-3 border-b border-slate-700 bg-slate-800/50 flex items-center justify-between">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Add Entry</span>
        <span class="text-[10px] text-slate-500 italic"><%= @tournament.mode %> mode</span>
      </div>
      <div class="p-4 space-y-4">
        <% if @tournament.mode_team? %>
          <div>
            <%= label_tag "tournament_entry[name]", "Boat/Team Name (Optional)", class: "block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5" %>
            <%= text_field_tag "tournament_entry[name]", nil, placeholder: "e.g. Bass Hunters",
                               class: "w-full h-10 px-3 rounded bg-slate-800 border border-slate-700 text-sm text-slate-100 focus:ring-1 focus:ring-blue-500 outline-none" %>
          </div>
        <% end %>

        <div>
          <span class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">Select Members (max <%= TournamentEntryMember::MAX_TEAM_MEMBERS %>)</span>
          <div class="max-h-48 overflow-y-auto pr-2 space-y-1 scrollbar-thin scrollbar-thumb-slate-700">
            <% available.each do |u| %>
              <label class="flex items-center gap-3 p-2 rounded hover:bg-slate-800 cursor-pointer transition-colors group">
                <%= check_box_tag "tournament_entry[member_user_ids][]", u.id, false, class: "h-4 w-4 rounded border-slate-700 bg-slate-700 text-blue-600" %>
                <span class="text-sm text-slate-300 group-hover:text-white transition-colors"><%= u.name %></span>
              </label>
            <% end %>
          </div>
        </div>

        <%= submit_tag(@tournament.mode_team? ? "Add Team Entry" : "Add Individual Entries",
                       class: "w-full h-10 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold transition-colors cursor-pointer") %>
      </div>
    </div>
  <% end %>
<% end %>

<div class="space-y-3">
  <% if @tournament.tournament_entries.any? %>
    <% @tournament.tournament_entries
         .includes(tournament_entry_members: :user).order(id: :desc).each do |entry| %>
      <div class="bg-slate-900 border border-slate-700 rounded-lg p-3 group hover:border-slate-500 transition-colors">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <% if entry.name.present? %>
              <div class="text-sm font-bold text-white truncate"><%= entry.name %></div>
            <% end %>
            <% if @tournament.mode_team? %>
              <ul class="mt-1 space-y-1">
                <% entry.tournament_entry_members.each do |m| %>
                  <li class="flex items-center justify-between text-xs">
                    <span class="text-slate-300"><%= m.user.name %></span>
                    <% unless locked %>
                      <%= button_to "Remove",
                                    admin_tournament_tournament_entry_tournament_entry_member_path(
                                      tournament_id: @tournament.id, tournament_entry_id: entry.id, id: m.id),
                                    method: :delete,
                                    data: { turbo_confirm: "Remove #{m.user.name} from #{entry.name.presence || 'this team'}?" },
                                    class: "h-6 px-2 text-[10px] rounded bg-slate-800 hover:bg-slate-700 text-slate-300" %>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <div class="text-xs text-slate-400 truncate">
                <%= entry.users.map(&:name).join(", ") %>
              </div>
            <% end %>
          </div>
          <% unless locked %>
            <%= button_to admin_tournament_tournament_entry_path(tournament_id: @tournament.id, id: entry.id),
                          method: :delete,
                          data: { turbo_confirm: "Remove this entry?" },
                          class: "text-slate-500 hover:text-red-400 p-1 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          <% end %>
        </div>

        <% if @tournament.mode_team? && !locked %>
          <%= form_with url: admin_tournament_tournament_entry_path(tournament_id: @tournament.id, id: entry.id),
                        method: :patch, local: true, class: "mt-2 flex gap-2" do %>
            <%= text_field_tag "tournament_entry[name]", entry.name, placeholder: "Boat name",
                               class: "flex-1 h-8 px-2 rounded bg-slate-800 border border-slate-700 text-slate-100 text-xs" %>
            <%= submit_tag "Rename",
                           class: "h-8 px-2 rounded bg-slate-700 hover:bg-slate-600 text-slate-100 text-xs" %>
          <% end %>

          <% candidates = current_club.members.active
               .where.not(id: entry.tournament_entry_members.select(:user_id))
               .order(:name) %>
          <% if candidates.any? && entry.tournament_entry_members.size < TournamentEntryMember::MAX_TEAM_MEMBERS %>
            <%= form_with url: admin_tournament_tournament_entry_tournament_entry_members_path(
                            tournament_id: @tournament.id, tournament_entry_id: entry.id),
                          local: true, class: "mt-2 flex gap-2" do %>
              <%= select_tag :user_id,
                             options_from_collection_for_select(candidates, :id, :name),
                             class: "flex-1 h-8 px-2 rounded bg-slate-800 border border-slate-700 text-slate-100 text-xs" %>
              <%= submit_tag "Add",
                             class: "h-8 px-2 rounded bg-blue-600 hover:bg-blue-700 text-white text-xs" %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-center py-8 text-slate-500 text-sm italic border-2 border-dashed border-slate-800 rounded-xl">No entries yet</p>
  <% end %>
</div>
