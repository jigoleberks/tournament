<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold">Tournaments</h1>
</div>

<div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden">
  <% if @tournaments.any? %>
    <ul class="divide-y divide-slate-700">
      <% @tournaments.each do |t| %>
        <li class="p-6 hover:bg-slate-700/50 transition-colors flex items-center justify-between">
          <div>
            <%= link_to t.name, admin_club_tournament_path(@foreign_club, t),
                        class: "text-xl font-medium text-blue-400 hover:text-blue-300" %>
            <div class="flex items-center gap-3 mt-1 text-sm text-slate-400">
              <span><%= t.starts_at.strftime("%B %d, %Y") %></span>
              <% unless t.local %>
                <span class="px-2 py-0.5 rounded-full bg-slate-700 text-xs font-medium">(away)</span>
              <% end %>
              <span>•</span>
              <span><%= t.tournament_entries.count %> entries</span>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="p-12 text-center">
      <p class="text-slate-400 italic">No tournaments yet for this club.</p>
    </div>
  <% end %>
</div>
