<div class="mb-8">
  <h1 class="text-3xl font-bold"><%= @club.name %></h1>
</div>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
    <div class="text-xs text-slate-400 uppercase tracking-wider">Members</div>
    <div class="text-3xl font-bold text-white mt-1"><%= @member_count %></div>
  </div>
  <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
    <div class="text-xs text-slate-400 uppercase tracking-wider">Tournaments</div>
    <div class="text-3xl font-bold text-white mt-1"><%= @tournament_count %></div>
  </div>
  <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
    <div class="text-xs text-slate-400 uppercase tracking-wider">Active</div>
    <div class="text-3xl font-bold text-white mt-1"><%= @active_tournament_count %></div>
  </div>
  <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
    <div class="text-xs text-slate-400 uppercase tracking-wider">Catches</div>
    <div class="text-3xl font-bold text-white mt-1"><%= @catch_count %></div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <%= link_to admin_club_tournaments_path(@club), class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Tournaments</h2>
    <p class="text-slate-400 text-sm">Past and upcoming tournaments for this club.</p>
  <% end %>

  <%= link_to admin_club_members_path(@club), class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Members</h2>
    <p class="text-slate-400 text-sm">Roster, invitations, and sign-in codes.</p>
  <% end %>

  <%= link_to admin_club_catches_path(@club), class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Catches</h2>
    <p class="text-slate-400 text-sm">Full catch history across all tournaments.</p>
  <% end %>

  <%= link_to admin_club_tournament_templates_path(@club), class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Templates</h2>
    <p class="text-slate-400 text-sm">Reusable scoring slot configurations.</p>
  <% end %>

  <%= link_to admin_club_rules_path(@club), class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Rules</h2>
    <p class="text-slate-400 text-sm">Open water and ice rules, with revision history.</p>
  <% end %>
</div>
