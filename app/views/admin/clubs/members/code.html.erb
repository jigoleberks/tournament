<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold">Manual Sign-in</h1>
  <%= link_to "Back to Members", admin_club_members_path(@foreign_club),
              class: "text-slate-400 hover:text-white transition-colors" %>
</div>

<div class="max-w-xl">
  <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
    <div class="p-6 border-b border-slate-700 bg-slate-700/30">
      <h2 class="text-lg font-semibold">One-time Code for <%= @member.name %></h2>
      <p class="text-sm text-slate-400 mt-1">Valid for 10 minutes. Provide this to the member now.</p>
    </div>

    <div class="p-12 text-center">
      <div class="text-6xl font-mono tracking-[0.25em] text-emerald-400 font-bold bg-slate-900 py-8 rounded-2xl border border-slate-700">
        <%= @code %>
      </div>

      <div class="mt-12 flex justify-center">
        <%= link_to "Return to Member List", admin_club_members_path(@foreign_club),
                    class: "h-12 px-8 inline-flex items-center rounded-lg bg-slate-700 hover:bg-slate-600 text-white font-medium transition-colors"  %>
      </div>
    </div>
  </div>
</div>
