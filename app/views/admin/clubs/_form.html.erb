<%= form_with model: club, url: form_url, scope: :club, local: true, class: "space-y-6" do |f| %>
  <% if club.errors.any? %>
    <div class="bg-red-900/40 border border-red-800 rounded-lg p-4">
      <ul class="text-red-400 text-sm list-disc list-inside">
        <% club.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-semibold text-slate-300 mb-1.5" %>
    <%= f.text_field :name, placeholder: "e.g. Northtown Anglers",
                     class: "w-full h-11 px-4 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none transition-all" %>
  </div>

  <div class="pt-4">
    <%= f.submit submit_label,
                 class: "w-full h-12 px-6 text-base font-bold rounded-lg bg-blue-600 hover:bg-blue-700 text-white shadow-lg shadow-blue-900/20 transition-all cursor-pointer" %>
  </div>
<% end %>
