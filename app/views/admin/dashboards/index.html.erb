<h1 class="text-2xl font-bold mb-6 text-white">Admin Dashboard</h1>

<% if current_user.admin? %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
      <div class="text-xs text-slate-400 uppercase tracking-wider">Total clubs</div>
      <div class="text-3xl font-bold text-white mt-1"><%= @total_clubs %></div>
    </div>
    <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
      <div class="text-xs text-slate-400 uppercase tracking-wider">Active members</div>
      <div class="text-3xl font-bold text-white mt-1"><%= @total_active_members %></div>
    </div>
    <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
      <div class="text-xs text-slate-400 uppercase tracking-wider">Active tournaments</div>
      <div class="text-3xl font-bold text-white mt-1"><%= @active_tournaments %></div>
    </div>
    <div class="p-5 bg-slate-800 rounded-xl border border-slate-700">
      <div class="text-xs text-slate-400 uppercase tracking-wider">Catches last 7 days</div>
      <div class="text-3xl font-bold text-white mt-1"><%= @catches_last_7_days %></div>
    </div>
  </div>

  <div class="p-5 bg-slate-800 rounded-xl border border-slate-700 mb-6">
    <div class="text-xs text-slate-400 uppercase tracking-wider mb-3">Server status</div>
    <h2 class="sr-only">Server status</h2>
    <dl class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-2 text-sm">
      <% { "App build" => @server_info[:app_build], "Environment" => @server_info[:rails_env],
           "Ruby" => @server_info[:ruby_version], "Rails" => @server_info[:rails_version],
           "Puma" => @server_info[:puma_version], "Postgres" => @server_info[:postgres_version] }.each do |label, value| %>
        <div class="flex justify-between gap-2 border-b border-slate-700/50 pb-1">
          <dt class="text-slate-400"><%= label %></dt>
          <dd class="text-slate-100 font-mono text-xs"><%= value %></dd>
        </div>
      <% end %>
    </dl>
    <% if @server_info[:booted_at] %>
      <p class="text-xs text-slate-500 mt-3">Booted <%= time_ago_in_words(@server_info[:booted_at]) %> ago</p>
    <% end %>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <%= link_to admin_tournaments_path, class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Tournaments</h2>
    <p class="text-slate-400 text-sm">Manage active and past tournaments, set up rules, and assign judges.</p>
  <% end %>

  <%= link_to admin_members_path, class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Members</h2>
    <p class="text-slate-400 text-sm">View club members, issue invitation codes, and manage roles.</p>
  <% end %>

  <%= link_to admin_tournament_templates_path, class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Templates</h2>
    <p class="text-slate-400 text-sm">Create and manage reusable scoring slots and rules for common tournament formats.</p>
  <% end %>

  <%= link_to admin_catches_path, class: "block p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-slate-500 transition-colors" do %>
    <h2 class="text-xl font-semibold text-white mb-2">Catch History</h2>
    <p class="text-slate-400 text-sm">Review all catches submitted across the club.</p>
  <% end %>
</div>
