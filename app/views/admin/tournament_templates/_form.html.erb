<%= form_with model: [:admin, @template], local: true, class: "space-y-8" do |f| %>
  <% if @template.errors.any? %>
    <div class="bg-red-900/40 border border-red-800 rounded-lg p-4">
      <ul class="text-red-400 text-sm list-disc list-inside">
        <% @template.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-4">
      <div>
        <%= f.label :name, class: "block text-sm font-semibold text-slate-300 mb-1.5" %>
        <%= f.text_field :name, placeholder: "e.g. Wednesday Night Solo",
                         class: "w-full h-11 px-4 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none transition-all" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :mode, class: "block text-sm font-semibold text-slate-300 mb-1.5" %>
          <%= f.select :mode, TournamentTemplate.modes.keys, {},
                       class: "w-full h-11 px-3 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none transition-all" %>
        </div>
        <div>
          <%= f.label :default_duration_days, "Duration (Days)", class: "block text-sm font-semibold text-slate-300 mb-1.5" %>
          <%= f.number_field :default_duration_days, min: 1,
                             class: "w-full h-11 px-4 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none transition-all" %>
        </div>
      </div>

      <div class="pt-2">
        <label class="flex items-start gap-3 cursor-pointer group">
          <div class="mt-1">
            <%= f.check_box :awards_season_points, class: "h-5 w-5 rounded border-slate-700 bg-slate-900 text-blue-600 focus:ring-offset-slate-800" %>
          </div>
          <div>
            <span class="block font-medium text-slate-200 group-hover:text-white transition-colors">Awards Season Points</span>
            <span class="block text-xs text-slate-500 italic">Cloned tournaments will be points-eligible by default.</span>
          </div>
        </label>
      </div>
    </div>

    <div class="bg-slate-900/50 rounded-xl p-6 border border-slate-700 space-y-4">
      <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
        </svg>
        Weekly Schedule
      </h3>
      
      <div>
        <%= f.label :default_weekday, "Day of week", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
        <%= f.select :default_weekday,
                     Date::DAYNAMES.each_with_index.map { |n, i| [n, i] },
                     { include_blank: "No automatic schedule" },
                     class: "w-full h-10 px-3 rounded bg-slate-800 border border-slate-700 text-sm text-slate-100" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :default_start_time, "Start time", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
          <%= f.time_field :default_start_time,
                           class: "w-full h-10 px-3 rounded bg-slate-800 border border-slate-700 text-sm text-slate-100" %>
        </div>
        <div>
          <%= f.label :default_end_time, "End time", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
          <%= f.time_field :default_end_time,
                           class: "w-full h-10 px-3 rounded bg-slate-800 border border-slate-700 text-sm text-slate-100" %>
        </div>
      </div>
      <p class="text-[10px] text-slate-500 italic">Enables one-tap cloning for the next occurrence.</p>
    </div>
  </div>

  <div class="pt-6 border-t border-slate-700">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-bold">Scoring Slots</h3>
      <p class="text-xs text-slate-500 italic">Save template to add more slots</p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      <%= f.fields_for :tournament_template_scoring_slots do |sf| %>
        <div class="bg-slate-900 rounded-xl p-4 border border-slate-700 relative group">
          <div class="grid grid-cols-1 gap-3">
            <div>
              <%= sf.label :species_id, "Species", class: "block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1" %>
              <%= sf.collection_select :species_id, current_user.club.species.order(:name), :id, :name,
                                       { include_blank: "—" },
                                       class: "w-full h-10 px-3 rounded bg-slate-800 border border-slate-700 text-sm text-slate-100" %>
            </div>
            <div>
              <%= sf.label :slot_count, "Slot Count", class: "block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1" %>
              <%= sf.number_field :slot_count, min: 1, value: sf.object.slot_count || 1,
                                  class: "w-full h-10 px-3 rounded bg-slate-800 border border-slate-700 text-sm text-slate-100" %>
            </div>
          </div>

          <% if sf.object.persisted? %>
            <label class="mt-3 flex items-center gap-2 text-xs text-red-400 cursor-pointer hover:text-red-300 transition-colors">
              <%= sf.check_box :_destroy, class: "h-4 w-4 rounded border-slate-700 bg-slate-900 text-red-600 focus:ring-offset-slate-900" %>
              <span>Remove this slot</span>
            </label>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end pt-6 border-t border-slate-700">
    <%= f.submit class: "h-12 px-8 text-base font-bold rounded-lg bg-blue-600 hover:bg-blue-700 text-white shadow-lg shadow-blue-900/20 transition-all cursor-pointer" %>
  </div>
<% end %>
