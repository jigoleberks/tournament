<div class="flex items-center justify-between mt-4 mb-4">
  <h1 class="text-2xl font-semibold">Fishing Map</h1>
  <%= link_to "List view", catches_path, class: "text-blue-400 font-medium" %>
</div>

<div class="flex items-center justify-between bg-slate-800 rounded-lg p-3 mb-4">
  <%= link_to "←", map_catches_path(date: @date - 1.day), class: "text-xl px-2" %>
  <div class="text-center">
    <div class="font-bold"><%= @date.strftime("%A, %b %d") %></div>
    <div class="text-xs text-slate-400"><%= pluralize(@catches.count, "catch") %></div>
  </div>
  <%= link_to "→", map_catches_path(date: @date + 1.day), class: "text-xl px-2" %>
</div>

<div class="relative w-full aspect-[3/4] rounded-xl overflow-hidden shadow-xl border border-slate-700"
     data-controller="map"
     data-map-points-value="<%= @map_points.to_json %>">
  <div class="absolute inset-0 bg-slate-800 flex items-center justify-center text-slate-500 italic">
    Loading map...
  </div>
</div>

<div class="mt-6">
  <h2 class="text-lg font-semibold mb-3">Catches on this day</h2>
  <% if @catches.any? %>
    <ul class="space-y-2">
      <% @catches.each do |c| %>
        <li class="bg-slate-800 rounded-lg p-3 flex items-center gap-3">
          <% if c.photo.attached? %>
            <%= image_tag url_for(c.photo), class: "w-16 h-16 object-cover rounded bg-black flex-shrink-0" %>
          <% end %>
          <div class="flex-1 min-w-0">
            <div class="font-bold truncate"><%= c.species.name %></div>
            <div class="text-sm"><%= format_length_dual(c.length_inches) %></div>
            <div class="text-xs text-slate-500"><%= c.captured_at_device.strftime("%l:%M %p") %></div>
          </div>
          <%= link_to "View", catch_path(c), class: "px-3 py-1 bg-slate-700 rounded text-sm font-medium" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-slate-400 italic">No catches for this day.</p>
  <% end %>
</div>
