<div class="flex items-center justify-between mt-4 mb-3">
  <h1 class="text-2xl font-semibold">My catches</h1>
  <%= link_to "View map", map_catches_path(request.query_parameters), class: "text-blue-400 font-medium" %>
</div>

<%= render "shared/catch_calendar",
           month_start: @month_start,
           current_start: @selected_start,
           current_end: @selected_end,
           counts_by_date: @counts_by_date,
           path_helper: :catches_path,
           params: request.query_parameters %>

<%= form_with url: catches_path, method: :get, local: true,
              data: { controller: "auto-submit", action: "change->auto-submit#submit" },
              class: "flex flex-wrap items-center gap-3 mt-3 mb-3 text-sm" do %>
  <% request.query_parameters.except(:species, :sort, :start, :end, :controller, :action).each do |k, v| %>
    <%= hidden_field_tag k, v %>
  <% end %>
  <%= hidden_field_tag :start, params[:start] if params.key?(:start) %>
  <%= hidden_field_tag :end,   params[:end]   if params.key?(:end) %>

  <%= link_to "Show all dates",
              catches_path(request.query_parameters.except(:start, :end, :controller, :action).merge(start: "", end: "")),
              "data-test": "show-all-dates",
              class: "text-blue-400" %>

  <span class="ml-auto"></span>

  <label class="text-slate-300">Species</label>
  <%= select_tag :species,
                 options_for_select(
                   [["All species", ""]] + @available_species.map { |s| [s.name, s.id] },
                   @species_filter_id&.to_s
                 ),
                 class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>

  <label class="text-slate-300">Sort</label>
  <%= select_tag :sort,
                 options_for_select(
                   [["Newest first", "newest"], ["Longest first", "longest"], ["Shortest first", "shortest"]],
                   @sort.to_s
                 ),
                 class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
<% end %>

<% if @catches.any? %>
  <ul class="grid grid-cols-2 gap-2 mt-4">
    <% @catches.each do |c| %>
      <li class="bg-slate-800 rounded-lg p-2 active:bg-slate-700">
        <%= link_to catch_path(c.id), class: "block" do %>
          <% if c.photo.attached? %>
            <%= image_tag url_for(c.photo), class: "w-full h-32 object-cover rounded bg-black" %>
          <% else %>
            <div class="w-full h-32 rounded bg-black flex items-center justify-center text-slate-500 text-sm">no photo</div>
          <% end %>
          <div class="text-xs text-slate-300 mt-2 leading-snug">
            <div class="font-medium text-slate-100"><%= c.species.name %></div>
            <div><%= format_length_dual(c.length_inches) %></div>
            <div class="text-slate-500"><%= c.captured_at_device.strftime("%b %d %Y · %l:%M %p") %></div>
            <% if c.disqualified? %>
              <div class="text-red-400 mt-1">disqualified</div>
            <% elsif c.flags.any? %>
              <div class="mt-1"><%= render "catches/flag_badges", catch_record: c %></div>
            <% elsif c.needs_review? %>
              <div class="text-amber-400 mt-1">needs review</div>
            <% end %>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-slate-400 italic mt-4">No catches in this view.</p>
<% end %>
