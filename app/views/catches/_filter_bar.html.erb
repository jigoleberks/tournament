<%# locals: path_helper:, available_species:, species_filter_id:, lake_filter_key:, sort: nil, show_sort: true, available_baits: nil, structure_filter: nil, bait_filter_id: nil %>
<%= form_with url: public_send(path_helper), method: :get, local: true,
              data: { controller: "auto-submit", action: "change->auto-submit#submit" },
              class: "flex flex-wrap items-center gap-3 mt-3 mb-3 text-sm" do %>
  <% request.query_parameters.except(:species, :sort, :lake, :start, :end, :min_length, :structure, :bait_id, :controller, :action).each do |k, v| %>
    <%= hidden_field_tag k, v %>
  <% end %>
  <%# Preserve :start/:end across auto-submit of the species/lake/sort %>
  <%# dropdowns; the except() above keeps them out of the generic carry-through %>
  <%# so they only render here, where blank strings (?start=&end=) are kept %>
  <%# verbatim — losing them would snap the page back to default_date_range. %>
  <%= hidden_field_tag :start, params[:start] if params.key?(:start) %>
  <%= hidden_field_tag :end,   params[:end]   if params.key?(:end) %>

  <%= link_to "Show all dates",
              public_send(path_helper, request.query_parameters.except(:start, :end, :month, :controller, :action).merge(start: "", end: "")),
              "data-test": "show-all-dates",
              class: "text-blue-400" %>

  <span class="ml-auto"></span>

  <label class="text-slate-300">Species</label>
  <%= select_tag :species,
                 options_for_select(
                   [["All species", ""]] + available_species.map { |s| [s.name, s.id] },
                   species_filter_id&.to_s
                 ),
                 class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>

  <label class="text-slate-300">Lake</label>
  <%= select_tag :lake,
                 options_for_select(
                   [["All lakes", ""]] +
                   Geofence::Lakes.all.map { |l| [l[:name], l[:key]] } +
                   [["Other (no lake match)", "other"]],
                   lake_filter_key.to_s
                 ),
                 class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>

  <% if show_sort %>
    <label class="text-slate-300">Sort</label>
    <%= select_tag :sort,
                   options_for_select(
                     [["Newest first", "newest"], ["Longest first", "longest"], ["Shortest first", "shortest"]],
                     sort.to_s
                   ),
                   class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
  <% end %>

  <label class="text-slate-300">≥</label>
  <%= number_field_tag :min_length, params[:min_length].presence,
                       min: 0, step: "0.5", placeholder: "in",
                       "data-test": "min-length",
                       class: "h-10 w-20 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>

  <% if local_assigns[:available_baits] %>
    <label class="text-slate-300">Structure</label>
    <%= select_tag :structure,
                   options_for_select(
                     [["Any structure", ""]] + Catch.structures.keys.map { |k| [k.humanize, k] },
                     local_assigns[:structure_filter].to_s
                   ),
                   "data-test": "structure-filter",
                   class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>

    <label class="text-slate-300">Bait</label>
    <%= select_tag :bait_id,
                   options_for_select(
                     [["Any bait", ""]] + local_assigns[:available_baits].map { |b| [b.display_name, b.id] },
                     local_assigns[:bait_filter_id].to_s
                   ),
                   "data-test": "bait-filter",
                   class: "h-10 px-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100" %>
  <% end %>
<% end %>
