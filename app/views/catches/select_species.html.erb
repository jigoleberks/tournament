<h1 class="text-2xl font-semibold mt-4 mb-2">What did you catch?</h1>
<p class="text-slate-400 text-sm mb-4">
  Pick the species, then you'll log the details.
</p>

<% default_species = @species.find { |s| s.name.casecmp?("walleye") } || @species.first %>
<ul class="space-y-2">
  <% @species.each do |s| %>
    <li>
      <%= link_to s.name,
                  new_catch_path(species_id: s.id, teammate_user_id: @teammate_user_id),
                  class: (s == default_species ?
                    "block w-full h-20 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white text-lg font-semibold leading-[5rem]" :
                    "block w-full h-14 px-4 rounded-lg bg-slate-800 active:bg-slate-700 text-slate-100 text-base font-medium leading-[3.5rem]") %>
    </li>
  <% end %>
</ul>

<%= link_to "Cancel", root_path,
            class: "block w-full h-12 px-4 mt-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
