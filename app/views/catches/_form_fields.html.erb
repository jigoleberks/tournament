<%#
  Shared core catch form. Locals:
    csrf_token: String  - authenticity token ("" on the offline shell)
    teammate:   User?    - present only when logging for a teammate (online)
    offline:    Boolean  - true on the cached /offline shell; suppresses the
                           release-video block (needs live tournament data)
                           AND the logbook two-step flow (needs server-rendered baits)
%>
<% offline   = local_assigns.fetch(:offline, false) %>
<% teammate  = local_assigns.fetch(:teammate, nil) %>
<% logbook   = !offline && logbook_enabled? %>
<% available_baits = (logbook && current_user) ? current_user.baits.active.order(:created_at) : [] %>
<% recent_bait_ids = (logbook && current_user) ?
     current_user.catches.where.not(bait_id: nil).order(captured_at_device: :desc).limit(25).pluck(:bait_id).uniq.first(4) : [] %>
<% baits_by_id = available_baits.index_by(&:id) %>
<% recent_baits = recent_bait_ids.filter_map { |id| baits_by_id[id] } %>
<% all_species = Species.in_log_order %>
<% default_species = all_species.find { |s| s.name.casecmp?("walleye") } || all_species.first %>
<% length_caps = all_species.each_with_object({}) do |s, h|
     cap = Catch.length_cap_for(s)
     h[s.id] = cap if cap
   end %>
<% tagged_species_id = all_species.find(&:tagged_walleye?)&.id %>

<div data-controller="catch-form photo-capture video-capture"
     data-catch-form-csrf-token-value="<%= local_assigns.fetch(:csrf_token, "") %>"
     data-catch-form-caps-by-species-id-value="<%= length_caps.to_json %>"
     data-catch-form-tagged-species-id-value="<%= tagged_species_id %>"
     data-catch-form-teammate-user-id-value="<%= teammate&.id %>"
     data-action="photo-capture:captured->catch-form#onPhotoCaptured
                  video-capture:captured->catch-form#onVideoCaptured
                  video-capture:failed->catch-form#onVideoFailed">

  <div<%= " data-catch-form-target=\"step1\"".html_safe if logbook %>>

    <label for="catch_species_id" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Species</label>
    <select id="catch_species_id" data-catch-form-target="speciesSelect" data-action="change->catch-form#refresh"
            class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">
      <% all_species.each do |s| %>
        <option value="<%= s.id %>"<%= " selected" if s == default_species %>><%= s.name %></option>
      <% end %>
    </select>

    <label for="catch_length_inches" data-catch-form-target="lengthLabel" class="block text-sm font-medium text-slate-300 mt-4 mb-1">
      <%= current_user&.metric? ? "Length (cm)" : "Length (in)" %>
    </label>
    <input id="catch_length_inches" type="number"
           step="0.25"
           min="0"
           data-catch-form-target="lengthInput"
           data-catch-form-unit="<%= current_user&.length_unit || "inches" %>"
           data-action="input->catch-form#refresh"
           class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">

    <label class="block text-sm font-medium text-slate-300 mt-4 mb-1">Length unit</label>
    <div class="flex gap-2">
      <% User::LENGTH_UNITS.each do |unit| %>
        <label class="flex-1">
          <input type="radio" name="length_unit_toggle" value="<%= unit %>"
                 <%= "checked" if (current_user&.length_unit || "inches") == unit %>
                 data-action="change->catch-form#setUnit"
                 class="sr-only peer">
          <span class="block w-full h-12 leading-[3rem] text-center rounded-lg bg-slate-700 peer-checked:bg-blue-600 text-slate-100 peer-checked:text-white cursor-pointer">
            <%= unit == "inches" ? "Inches" : "Centimeters" %>
          </span>
        </label>
      <% end %>
    </div>

    <div data-catch-form-target="tagWrapper" class="hidden">
      <label for="catch_tag_number" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Science tag #</label>
      <input id="catch_tag_number" type="text" maxlength="16"
             autocapitalize="characters" autocomplete="off"
             data-catch-form-target="tagInput"
             data-action="input->catch-form#refresh blur->catch-form#uppercaseTag"
             placeholder="e.g. A1234"
             class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100 uppercase">

      <label for="catch_weight_text" class="block text-sm font-medium text-slate-300 mt-3 mb-1">
        Weight <span class="text-slate-500">(recommended)</span>
      </label>
      <input id="catch_weight_text" type="text" maxlength="32"
             autocomplete="off"
             data-catch-form-target="weightInput"
             placeholder="e.g. 4 lbs 3oz"
             class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">
    </div>

    <% unless logbook %>
      <label for="catch_note" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Notes (private)</label>
      <textarea id="catch_note" name="catch[note]" maxlength="500" rows="4"
                data-catch-form-target="noteInput"
                placeholder="Only you will see these notes."
                class="w-full px-3 py-2 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100"></textarea>
    <% end %>

    <h3 class="text-lg font-semibold mt-6 mb-2">Photo</h3>
    <input type="file" accept="image/*" capture="environment"
           data-photo-capture-target="input"
           data-action="change->photo-capture#onChange"
           class="hidden">
    <img data-photo-capture-target="preview" alt=""
         class="hidden w-full aspect-[3/4] object-contain rounded-lg bg-black">
    <div class="flex gap-2 mt-2">
      <button type="button" data-photo-capture-target="openButton"
              data-action="photo-capture#open"
              class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Take photo</button>
      <button type="button" data-photo-capture-target="retakeButton"
              data-action="photo-capture#retake"
              class="hidden flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Retake</button>
    </div>

    <% unless offline %>
      <% video_required = Tournaments::ActiveForUser.call(user: current_user).any?(&:requires_release_video) %>
      <% if video_required %>
        <h3 class="text-lg font-semibold mt-6 mb-2">Release video</h3>
        <video data-video-capture-target="video" autoplay muted playsinline
               class="w-full max-h-80 object-cover rounded-lg bg-black"></video>
        <div class="flex gap-2 mt-2">
          <button type="button" data-action="video-capture#start"
                  class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Start recording</button>
          <button type="button" data-action="video-capture#stop"
                  class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Stop</button>
        </div>
        <button type="button" data-action="video-capture#markFailed"
                class="w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 mt-2">Mark video failed and submit anyway</button>
        <video data-video-capture-target="preview" controls
               class="w-full max-h-80 object-contain rounded-lg bg-black mt-2"></video>
      <% end %>
    <% end %>

    <% if logbook %>
      <button type="button"
              data-action="catch-form#next"
              data-test="next-button"
              class="w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white mt-4">Next</button>
    <% end %>
  </div>

  <% if logbook %>
    <div data-catch-form-target="step2" hidden class="mt-2">
      <h2 class="text-xl font-semibold mt-2 mb-2">Trip details</h2>
      <p class="text-sm text-slate-400 mb-4">All fields optional — fill in what you know.</p>

      <% if recent_baits.any? %>
        <label class="block text-sm font-medium text-slate-300 mb-1">Recent baits</label>
        <div class="flex flex-wrap gap-2 mb-3">
          <% recent_baits.each do |b| %>
            <button type="button" data-catch-form-target="recentBait"
                    data-catch-form-bait-id-param="<%= b.id %>"
                    data-action="catch-form#pickRecentBait"
                    class="px-3 h-10 rounded-full bg-slate-700 active:bg-slate-600 text-slate-100 text-sm"><%= b.display_name %></button>
          <% end %>
        </div>
      <% end %>

      <div class="flex items-end gap-2">
        <div class="flex-1">
          <label for="catch_bait_id" class="block text-sm font-medium text-slate-300 mb-1">Bait</label>
          <select id="catch_bait_id" data-catch-form-target="baitSelect"
                  data-action="change->catch-form#syncRecentBaitChips"
                  class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">
            <option value="">No bait selected</option>
            <% available_baits.each do |b| %>
              <option value="<%= b.id %>"><%= b.display_name %></option>
            <% end %>
          </select>
        </div>
        <button type="button" data-action="catch-form#toggleBaitQuickAdd"
                data-test="bait-quick-add-toggle"
                class="h-12 px-3 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-sm whitespace-nowrap">+ New</button>
      </div>

      <%# Quick-add: compose and save a bait without ever leaving the catch.
          Saves via fetch to /logbook/baits (JSON) and selects the new bait. %>
      <div data-catch-form-target="baitQuickAdd" hidden
           class="mt-3 bg-slate-800/60 border border-slate-700 rounded-lg p-3 space-y-4">
        <p class="text-sm font-medium text-slate-200">New bait</p>
        <% bait_vocab = Bait.chip_vocab(current_user) %>
        <% [
             ["Weight",                        "weight",        Bait::COMMON_WEIGHTS,   "e.g. 7/8 oz"],
             ["Lure",                          "lure_type",     bait_vocab[:lures],     "e.g. crankbait"],
             ["Lure colour",                   "color",         bait_vocab[:colors],    "e.g. blue/pink"],
             ["Plastic (optional)",            "plastic",       bait_vocab[:plastics],  "e.g. paddle tail"],
             ["Plastic colour (optional)",     "plastic_color", bait_vocab[:colors],    "e.g. motor oil"],
             ["Bait / tipping (optional)",     "bait_type",     bait_vocab[:tippings],  "e.g. jumbo minnow"],
           ].each do |chip_label, field, chips, placeholder| %>
          <div data-controller="chip-picker">
            <label class="block text-sm text-slate-300 mb-1"><%= chip_label %></label>
            <div class="flex flex-wrap gap-2">
              <% chips.each do |v| %>
                <button type="button" data-chip-picker-target="chip" data-action="chip-picker#pick" data-value="<%= v %>"
                        class="px-3 h-10 rounded-full bg-slate-700 active:bg-slate-600 text-slate-100 text-sm"><%= v %></button>
              <% end %>
              <button type="button" data-chip-picker-target="otherButton" data-action="chip-picker#other"
                      class="px-3 h-10 rounded-full border border-dashed border-slate-500 text-slate-400 text-sm">Other…</button>
            </div>
            <input type="text" data-bait-field="<%= field %>" placeholder="<%= placeholder %>"
                   data-chip-picker-target="input"
                   class="hidden w-full h-12 px-3 mt-2 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">
          </div>
        <% end %>
        <p data-catch-form-target="baitQuickAddStatus" class="text-amber-300 text-sm"></p>
        <div class="flex gap-2">
          <button type="button" data-action="catch-form#cancelBaitQuickAdd"
                  class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Cancel</button>
          <button type="button" data-action="catch-form#saveBaitQuickAdd"
                  data-catch-form-target="baitQuickAddSave" data-test="bait-quick-add-save"
                  class="flex-1 h-12 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white font-semibold">Save bait</button>
        </div>
      </div>

      <label for="catch_water_depth_feet" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Water depth (ft)</label>
      <input id="catch_water_depth_feet" type="number" step="0.5" min="0"
             data-catch-form-target="waterDepthInput"
             placeholder="e.g. 22"
             class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">

      <label for="catch_water_temperature_c" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Water temp (°C)</label>
      <input id="catch_water_temperature_c" type="number" step="0.1"
             data-catch-form-target="waterTempInput"
             placeholder="e.g. 18.5"
             class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">

      <label for="catch_structure" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Structure</label>
      <select id="catch_structure" data-catch-form-target="structureSelect"
              class="w-full h-12 px-3 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100">
        <option value="">No structure noted</option>
        <% Catch.structures.keys.each do |key| %>
          <option value="<%= key %>"><%= key.humanize %></option>
        <% end %>
      </select>

      <label for="catch_note" class="block text-sm font-medium text-slate-300 mt-4 mb-1">Notes (private)</label>
      <textarea id="catch_note" name="catch[note]" maxlength="500" rows="4"
                data-catch-form-target="noteInput"
                placeholder="Only you will see these notes."
                class="w-full px-3 py-2 rounded-lg bg-slate-800 border border-slate-700 text-base text-slate-100"></textarea>

      <div class="flex gap-2 mt-4">
        <button type="button" data-action="catch-form#back"
                data-test="back-button"
                class="flex-1 h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100">Back</button>
        <button data-catch-form-target="submitButton"
                data-action="catch-form#submit"
                class="flex-1 h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white disabled:opacity-60 disabled:cursor-not-allowed">Submit</button>
      </div>
    </div>
  <% else %>
    <button data-catch-form-target="submitButton"
            data-action="catch-form#submit"
            class="w-full h-14 px-6 text-lg font-semibold rounded-lg bg-blue-600 active:bg-blue-700 text-white mt-2 disabled:opacity-60 disabled:cursor-not-allowed">Submit</button>
  <% end %>

  <p data-catch-form-target="status" class="text-amber-300 text-sm mb-2 mt-4"></p>
</div>
