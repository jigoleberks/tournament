<h1 class="text-2xl font-semibold mt-4 mb-4">Catch</h1>

<div class="bg-slate-800 rounded-xl p-4 space-y-4">
  <% if @catch.photo.attached? %>
    <%
      filename_segments = [
        @catch.species&.name,
        (@catch.length_inches.present? ? "#{@catch.length_inches} in" : nil),
        @catch.captured_at_device&.strftime("%Y-%m-%d %H%M")
      ].compact
      download_filename = "#{filename_segments.join(' - ')}.jpg"
    %>
    <div data-controller="photo-save"
         data-photo-save-url-value="<%= url_for(@catch.photo) %>"
         data-photo-save-filename-value="<%= download_filename %>">
      <%= image_tag url_for(@catch.photo), class: "w-full max-h-96 object-contain rounded-lg bg-black" %>
      <button type="button"
              data-action="photo-save#save"
              class="mt-3 h-12 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white font-semibold w-full">
        Save photo
      </button>
    </div>
  <% else %>
    <div class="w-full h-64 rounded-lg bg-black flex items-center justify-center text-slate-500">no photo</div>
  <% end %>

  <% if @catch.video.attached? %>
    <%= video_tag url_for(@catch.video), controls: true, class: "w-full max-h-96 rounded-lg bg-black" %>
  <% end %>

  <dl class="text-slate-300 text-sm space-y-1">
    <div><dt class="inline text-slate-500">Angler:</dt> <dd class="inline text-slate-100"><%= @catch.user.name %></dd></div>
    <div><dt class="inline text-slate-500">Species:</dt> <dd class="inline"><%= @catch.species.name %></dd></div>
    <div><dt class="inline text-slate-500">Length:</dt> <dd class="inline"><%= format_length_dual(@catch.length_inches) %></dd></div>
    <div><dt class="inline text-slate-500">Captured:</dt> <dd class="inline"><%= @catch.captured_at_device.strftime("%b %d %Y · %l:%M %p %Z") %></dd></div>
    <% if @catch.latitude.present? %>
      <div><dt class="inline text-slate-500">GPS:</dt> <dd class="inline">~<%= @catch.latitude.to_f.round(2) %>, <%= @catch.longitude.to_f.round(2) %></dd></div>
    <% end %>
    <div><dt class="inline text-slate-500">Status:</dt>
      <dd class="inline">
        <% if @catch.disqualified? %>
          <span class="text-red-400">disqualified</span>
        <% elsif @catch.flags.any? %>
          <%= render "catches/flag_badges", catch_record: @catch %>
        <% elsif @catch.needs_review? %>
          <span class="text-amber-400">needs review</span>
        <% else %>
          <%= @catch.status %>
        <% end %>
      </dd>
    </div>
  </dl>
</div>

<% if @catch.temperature_c.present? || @catch.moon_phase.present? %>
  <div class="bg-slate-800 rounded-xl p-4 mt-3 space-y-1">
    <h2 class="text-sm font-semibold text-slate-400 mb-2">Conditions at catch</h2>
    <dl class="text-slate-300 text-sm space-y-1">
      <% if @catch.temperature_c.present? %>
        <div><dt class="inline text-slate-500">Temp:</dt> <dd class="inline"><%= format_temperature_dual(@catch.temperature_c) %></dd></div>
      <% end %>
      <% if @catch.barometric_pressure_hpa.present? %>
        <div><dt class="inline text-slate-500">Pressure:</dt> <dd class="inline"><%= @catch.barometric_pressure_hpa.to_f.round(1) %> hPa</dd></div>
      <% end %>
      <% if @catch.wind_speed_kph.present? %>
        <div><dt class="inline text-slate-500">Wind:</dt> <dd class="inline"><%= format_wind_dual(@catch.wind_speed_kph) %></dd></div>
      <% end %>
      <% if @catch.moon_phase.present? %>
        <div><dt class="inline text-slate-500">Moon:</dt> <dd class="inline"><%= @catch.moon_phase %></dd></div>
      <% end %>
    </dl>
  </div>
<% elsif @catch.latitude.present? %>
  <div class="bg-slate-800 rounded-xl p-4 mt-3 text-sm text-slate-500">Conditions fetching…</div>
<% end %>

<% if @catch.user_id == current_user.id %>
  <%= form_with model: @catch, method: :patch, local: true,
                class: "bg-slate-800 rounded-xl p-4 mt-3 space-y-2" do |f| %>
    <%= f.label :note, "Notes (private)", class: "block text-sm font-medium text-slate-300" %>
    <%= f.text_area :note, maxlength: 500, rows: 4,
                    class: "w-full px-3 py-2 rounded-lg bg-slate-900 border border-slate-700 text-base text-slate-100" %>
    <%= f.submit "Save notes",
                 class: "h-12 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white font-semibold w-full" %>
  <% end %>
<% end %>

<% if @action_tournament %>
  <div class="bg-slate-800 rounded-xl p-4 mt-3 space-y-3">
    <h2 class="text-sm font-semibold text-slate-300">Actions</h2>
    <div class="flex gap-2">
      <% if @catch.needs_review? || @catch.disputed? %>
        <%= button_to "Approve",
                      judges_tournament_catch_review_path(tournament_id: @action_tournament.id, catch_id: @catch.id),
                      method: :post,
                      params: { action_kind: "approve" },
                      form: { data: { turbo_confirm: "Approve this catch? It will count for scoring." } },
                      class: "flex-1 h-12 px-4 rounded-lg bg-emerald-600 active:bg-emerald-700 text-white font-semibold" %>
      <% end %>
      <%= button_to "Disqualify",
                    judges_tournament_catch_review_path(tournament_id: @action_tournament.id, catch_id: @catch.id),
                    method: :post,
                    params: { action_kind: "disqualify" },
                    form: { data: { turbo_confirm: "Disqualify this catch? It will be removed from the leaderboard." } },
                    class: "flex-1 h-12 px-4 rounded-lg bg-red-600 active:bg-red-700 text-white font-semibold" %>
    </div>

    <%= form_with url: judges_tournament_catch_manual_override_path(tournament_id: @action_tournament.id, catch_id: @catch.id),
                  local: true, class: "flex gap-2 items-end" do |f| %>
      <div class="flex-1">
        <label for="length_inches" class="block text-xs text-slate-400 mb-1">Edit length (in)</label>
        <%= number_field_tag :length_inches, @catch.length_inches, step: 0.25, min: 0,
                             class: "w-full h-12 px-3 rounded-lg bg-slate-900 border border-slate-700 text-base text-slate-100" %>
      </div>
      <%= submit_tag "Save", class: "h-12 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white font-semibold" %>
    <% end %>
  </div>
<% end %>
