<h1 class="text-2xl font-semibold mt-4 mb-2">Who's this catch for?</h1>
<p class="text-slate-400 text-sm mb-4">
  Log your own catch, or file one under a teammate's name (you'll be noted as the logger).
</p>

<ul class="space-y-2">
  <li>
    <%= link_to "Myself", new_catch_path,
                class: "block w-full h-14 px-4 rounded-lg bg-blue-600 active:bg-blue-700 text-white text-base font-semibold leading-[3.5rem]" %>
  </li>
  <% @teammates.each do |t| %>
    <li>
      <%= link_to t.name, new_catch_path(teammate_user_id: t.id),
                  class: "block w-full h-14 px-4 rounded-lg bg-slate-800 active:bg-slate-700 text-slate-100 text-base font-medium leading-[3.5rem]" %>
    </li>
  <% end %>
</ul>

<%= link_to "Cancel", root_path,
            class: "block w-full h-12 px-4 mt-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
