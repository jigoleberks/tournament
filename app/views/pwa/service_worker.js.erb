<%#
  Precache the /offline shell *and* the assets it needs to function. The shell is
  inert HTML without its stylesheet and Stimulus/Turbo modules, and `activate`
  purges the previous deploy's runtime cache — so without this, a cold launch
  with no signal right after a deploy would render the catch form with nothing
  wired up. Only same-origin asset paths are precachable: cache.addAll rejects
  atomically, so a cross-origin pin (the leaflet CDN) would brick the install.
%>
<% import_paths = JSON.parse(Rails.application.importmap.to_json(resolver: self))["imports"].values %>
<% precache = ["/offline", "/manifest.webmanifest", "/icon.png",
               "/icons/icon-180.png", "/icons/icon-192.png",
               asset_path("tailwind.css"), asset_path("leaflet.css")] +
              import_paths.select { |p| p.start_with?("/") } %>
const CACHE = <%= ("shell-" + ::AppVersion.current).to_json.html_safe %>;
const SHELL = <%= precache.to_json.html_safe %>;
const NAV_TIMEOUT_MS = 6000;

self.addEventListener("install", (event) => {
  event.waitUntil(caches.open(CACHE).then((c) => c.addAll(SHELL)));
  self.skipWaiting();
});

self.addEventListener("activate", (event) => {
  event.waitUntil(
    caches.keys().then((keys) => Promise.all(keys.filter((k) => k !== CACHE).map((k) => caches.delete(k))))
      .then(() => self.clients.claim())
  );
});

self.addEventListener("fetch", (event) => {
  const url = new URL(event.request.url);
  if (event.request.method !== "GET") return;
  if (url.pathname.startsWith("/api/")) return;
  if (url.origin !== location.origin) return;

  // Cache-first for immutable fingerprinted assets.
  if (url.pathname.startsWith("/assets/") || url.pathname.startsWith("/icons/") || url.pathname === "/manifest.webmanifest" || url.pathname === "/icon.png") {
    event.respondWith(
      caches.match(event.request).then((cached) => cached || fetch(event.request).then((res) => {
        if (res.status === 200) {
          const copy = res.clone();
          caches.open(CACHE).then((c) => c.put(event.request, copy));
        }
        return res;
      }))
    );
    return;
  }

  // Top-level navigations: network-first, but bounded by a timeout. On a weak
  // signal the request can hang for many seconds without throwing, leaving the
  // angler on a white screen. If the server hasn't returned response *headers*
  // within NAV_TIMEOUT_MS, abort and serve the static /offline shell so they can
  // log catches into IndexedDB. We race the response (≈TTFB), not full render: a
  // working-but-slow server still answers headers within the window; only a true
  // hang trips the fallback. The live response is NOT cached (it may contain
  // authenticated/personalized HTML).
  if (event.request.mode === "navigate") {
    event.respondWith(navigateWithTimeout(event.request));
    return;
  }

  // Network-first for everything else, and DO NOT cache the responses at
  // runtime: they may contain authenticated/personalized HTML, and serving a
  // cached copy after sign-out (or to another user on a shared device) would
  // leak data. Failed sub-resource and fetch/XHR requests get a bare 503; they're
  // never served the shell.
  event.respondWith(
    fetch(event.request).catch(() => new Response("offline", { status: 503 }))
  );
});

function offlineShell() {
  return caches.match("/offline").then((c) => c || new Response("offline", { status: 503 }));
}

async function navigateWithTimeout(request) {
  const controller = new AbortController();
  let timer;
  const timeout = new Promise((resolve) => {
    timer = setTimeout(() => { controller.abort(); resolve(null); }, NAV_TIMEOUT_MS);
  });
  // Swallow the fetch's own rejection (including the post-timeout AbortError) so a
  // settled race never leaves a floating unhandled rejection in the SW console. A
  // hard network error before the timer resolves null here too -> offline shell.
  const live = fetch(request, { signal: controller.signal }).catch(() => null);
  const res = await Promise.race([live, timeout]);
  clearTimeout(timer);
  return res || offlineShell();
}

self.addEventListener("sync", (event) => {
  if (event.tag === "catch-sync") {
    event.waitUntil(self.clients.matchAll().then((clients) => {
      clients.forEach((c) => c.postMessage({ type: "drain" }))
    }))
  }
});

// The /offline shell embeds the species list and length caps server-side at
// precache time; without this, "add a species for Saturday" never reaches
// offline shells until the next AppVersion bump. Pages ping this once per
// load while online (sw_register.js).
self.addEventListener("message", (event) => {
  if (event.data?.type !== "refresh-shell") return
  event.waitUntil(
    fetch("/offline").then((res) => {
      if (res.status === 200) return caches.open(CACHE).then((c) => c.put("/offline", res))
    }).catch(() => {})
  )
})

self.addEventListener("push", (event) => {
  if (!event.data) return
  // A non-JSON payload must degrade to a generic notification, not an
  // unhandled rejection that shows nothing.
  let data
  try { data = event.data.json() } catch (_) { data = { title: "Tournament update", body: event.data.text() } }
  event.waitUntil(
    self.registration.showNotification(data.title, {
      body: data.body,
      icon: "/icons/icon-192.png",
      badge: "/icons/icon-192.png",
      data: { url: data.url || "/" }
    })
  )
})

// APNs/FCM rotate push subscriptions behind our back (SW updates, OS events).
// Without this, the next send hits ExpiredSubscription, the server deletes the
// row, and the angler silently stops getting bumped/took-the-lead alerts while
// the home-page toggle still reads "on". Re-subscribe and swap the stored row.
const VAPID_PUBLIC_KEY = <%= VAPID[:public_key].to_json.html_safe %>;

self.addEventListener("pushsubscriptionchange", (event) => {
  event.waitUntil((async () => {
    try {
      const sub = event.newSubscription || await self.registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlB64ToUint8Array(VAPID_PUBLIC_KEY)
      })
      // The server may have already destroyed the old row (delivery deletes on
      // ExpiredSubscription), and oldSubscription can be null — possession of
      // the old endpoint then proves nothing, and refresh would 404 the fresh
      // subscription away. A CSRF token from /api/session is the fallback
      // same-origin proof that lets the server accept it anyway.
      let csrf = null
      try {
        const sess = await fetch("/api/session", { headers: { "Accept": "application/json" }, credentials: "include" })
        if (sess.ok) csrf = (await sess.json()).csrf_token
      } catch (_) {}
      await fetch("/api/push_subscriptions/refresh", {
        method: "POST",
        headers: Object.assign({ "Content-Type": "application/json" }, csrf ? { "X-CSRF-Token": csrf } : {}),
        credentials: "include",
        body: JSON.stringify({
          old_endpoint: event.oldSubscription && event.oldSubscription.endpoint,
          subscription: sub.toJSON()
        })
      })
    } catch (_) {
      // Signed out or offline: the home page's push toggle shows the true
      // state on next open; nothing useful to do from the SW.
    }
  })())
})

function urlB64ToUint8Array(b64) {
  const padding = "=".repeat((4 - (b64.length % 4)) % 4)
  const base64 = (b64 + padding).replace(/-/g, "+").replace(/_/g, "/")
  const raw = atob(base64)
  return new Uint8Array([...raw].map((c) => c.charCodeAt(0)))
}

self.addEventListener("notificationclick", (event) => {
  event.notification.close()
  const target = event.notification.data?.url || "/"
  // Match on exact pathname: includes("/") matched EVERY same-origin client,
  // focusing whatever page happened to be open instead of navigating.
  const targetPath = new URL(target, self.location.origin).pathname
  event.waitUntil(self.clients.matchAll({ type: "window" }).then((clients) => {
    const open = clients.find((c) => new URL(c.url).pathname === targetPath)
    if (open) return open.focus()
    return self.clients.openWindow(target)
  }))
})
