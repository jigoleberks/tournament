<div class="my-4">
  <% if @season_tag.nil? %>
    <h1 class="text-2xl font-bold mb-2">Past league nights</h1>
    <p class="text-slate-400">No season-points tournaments configured yet.</p>
  <% else %>
    <h1 class="text-2xl font-bold mb-3"><%= @season_tag %> League Nights</h1>
    <% tournaments = @tournaments.respond_to?(:to_a) ? @tournaments.to_a : @tournaments %>
    <% if tournaments.empty? %>
      <p class="text-slate-400">No league nights have ended yet.</p>
    <% else %>
      <ul class="bg-slate-800 rounded-xl divide-y divide-slate-700">
        <% tournaments.each do |t| %>
          <% winner = @winners[t.id] %>
          <% winner_label = winner ? winner.display_name : "—" %>
          <% visible = tournament_leaderboard_visible?(t) %>
          <% row = capture do %>
            <div class="flex justify-between items-center">
              <div>
                <div class="font-medium text-slate-100"><%= t.name %></div>
                <div class="text-xs text-slate-400">
                  <%= l(t.ends_at.to_date, format: :long) %> · Won by: <%= winner_label %>
                </div>
                <% unless visible %>
                  <div class="text-xs text-slate-400 mt-0.5">Ask an organizer to add you to see the leaderboard.</div>
                <% end %>
              </div>
              <% if visible %>
                <span class="text-slate-400">→</span>
              <% end %>
            </div>
          <% end %>
          <li class="p-3">
            <% if visible %>
              <%= link_to t, class: "block" do %><%= row %><% end %>
            <% else %>
              <div class="block"><%= row %></div>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  <% end %>
</div>
