<div class="my-4">
  <% if @season_tag.nil? %>
    <h1 class="text-2xl font-bold mb-2">Season standings</h1>
    <p class="text-slate-400">No season-points tournaments configured yet.</p>
  <% else %>
    <h1 class="text-2xl font-bold mb-3"><%= @season_tag %> League Night Standings</h1>
    <% if @standings.empty? %>
      <p class="text-slate-400">No points awarded yet this season.</p>
    <% else %>
      <table class="w-full text-base mb-4">
        <thead>
          <tr class="text-left text-sm text-slate-300 border-b border-slate-700">
            <th class="px-3 py-2">#</th>
            <th class="px-3 py-2">Angler</th>
            <th class="px-3 py-2 text-right">Points</th>
          </tr>
        </thead>
        <tbody>
          <% @standings.each_with_index do |row, i| %>
            <tr class="border-t border-slate-700">
              <td class="px-3 py-3"><%= i + 1 %></td>
              <td class="px-3 py-3 font-medium"><%= row[:user].name %></td>
              <td class="px-3 py-3 font-mono text-right"><%= row[:points] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
    <%= link_to "Past league nights →", season_points_tournaments_path,
                class: "block w-full h-12 px-4 rounded-lg bg-slate-700 active:bg-slate-600 text-slate-100 text-center leading-[3rem]" %>
  <% end %>
</div>
