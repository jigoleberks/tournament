<% if @revision.nil? %>
  <div class="my-6">
    <h1 class="text-2xl font-semibold mb-2">Rules</h1>
    <p class="text-slate-400">No rules published yet.</p>
  </div>
<% else %>
  <% season_label = @revision.season_open_water? ? "Open water rules" : "Ice rules" %>
  <div class="my-6">
    <h1 class="text-2xl font-semibold mb-4"><%= season_label %></h1>
    <% if (geofence_map_url = ENV["GEOFENCE_MAP_URL"]).present? %>
      <a href="<%= geofence_map_url %>"
         target="_blank"
         rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-3 py-2 mb-4 rounded bg-slate-800 hover:bg-slate-700 text-blue-300 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd" />
        </svg>
        2026 - Big Walleye - Local Boundaries
      </a>
    <% end %>
    <div class="prose prose-invert max-w-none text-slate-100
                [&_a]:text-blue-300 [&_a]:underline [&_a]:underline-offset-2
                [&_h1]:text-xl [&_h1]:font-semibold [&_h1]:mt-6 [&_h1]:mb-2
                [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:mt-5 [&_h2]:mb-2
                [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5
                [&_div]:my-2 [&_li]:my-1
                [&_code]:bg-slate-800 [&_code]:px-1 [&_code]:rounded
                [&_pre]:bg-slate-800 [&_pre]:p-3 [&_pre]:rounded">
      <%= @revision.body %>
    </div>
    <p class="text-xs text-slate-400 mt-6">
      Last edited <%= @revision.created_at.to_date.strftime("%b %-d, %Y") %><%
        if current_user.organizer_in?(current_club)
      %> by <%= @revision.edited_by_user.name %><% end %>
    </p>
  </div>
<% end %>
