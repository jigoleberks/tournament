# Copy this file to .env and fill in real values. Docker Compose loads .env automatically.
# All values have sensible defaults so the app boots even without this file — set what you need.

# --- Branding ---
# Shown in the manifest, mailer subjects, and the home-page header.
APP_NAME=Tournament

# --- Networking ---
# Public hostname where the PWA is reachable. For real-phone access (PWA camera requires HTTPS),
# point this at your Cloudflare tunnel hostname or equivalent.
APP_HOST=localhost

# Rails time zone name. Examples: "UTC", "Saskatchewan", "Eastern Time (US & Canada)".
APP_TIME_ZONE=UTC

# --- Mail (magic-link sign-in via Resend SMTP) ---
# Friendly From line. The address must be on a domain you've verified in Resend.
MAIL_FROM=Tournament <noreply@example.com>

# Resend API key. Leave blank to skip outbound mail entirely (use rails runner to fetch tokens).
RESEND_API_KEY=

# --- Rules page ---
# Optional URL shown as a "View geofence map" button on /rules. Leave blank to hide the button.
# For Google My Maps, use the /d/embed?mid=... form (not /d/viewer): Android intent-routes
# /d/viewer clicks to the Google Maps app, which can't render My Maps documents and shows
# "couldn't open map". The embed form stays in the browser. Set sharing to "Anyone with the link".
GEOFENCE_MAP_URL=

# --- Merch button ---
# Optional URL shown as a "Merch" button on the home page, linking members to an
# external apparel/clothing store. Leave blank or unset to hide the button entirely.
MERCH_URL=

# --- Web Push (VAPID) ---
# Generate a keypair with:
#   docker compose run --rm web bin/rails runner 'require "web_push"; k = WebPush.generate_key; puts "public:  #{k.public_key}"; puts "private: #{k.private_key}"'
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- First-time seed data (used by bin/rails db:seed) ---
SEED_CLUB_NAME=Example Fishing Club
SEED_ORGANIZER_NAME=Organizer
SEED_ORGANIZER_EMAIL=organizer@example.com
